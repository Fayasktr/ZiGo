<style>
    :root {
        --primary-orange: #FF5A1F;
        --primary-orange-hover: #E44D18;
        --deep-black: #0F0F0F;
        --off-white: #F9F9F9;
        --dark-navy: #1E293B;
        --gray-light: #E2E8F0;
        --white: #FFFFFF;
        --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* --- Header --- */
    header {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.92rem 5%;
        /* Main header padding recalibrated */
        /* Final calibration (+5% more) */
        /* Increased by 10% */
        z-index: 1000;
        transition: var(--transition);
        background-color: rgba(15, 15, 15, 0.7);
        backdrop-filter: blur(8px);
    }

    header.scrolled {
        background-color: rgba(15, 15, 15, 0.95);
        backdrop-filter: blur(10px);
        padding: 0.81rem 5%;
        /* Scrolled header padding recalibrated */
        /* Final calibration (+5% more) */
        /* Increased by 10% from 0.7rem */
        box-shadow: 0 4px 40px rgba(255, 90, 31, 0.4);
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
    }

    .logo img.icon {
        height: 76px;
        /* Final calibration (+5% more) */
        /* Increased by 10% from 65px */
        width: auto;
    }

    .logo img.name {
        height: 33px;
        /* Final calibration (+5% more) */
        /* Increased by 10% from 28px */
        width: auto;
        margin-top: 2px;
        mix-blend-mode: screen;
    }

    .nav-links {
        display: flex;
        gap: 2rem;
        list-style: none;
    }

    .nav-links a {
        color: var(--white);
        text-decoration: none;
        font-weight: 500;
        font-size: 0.95rem;
        opacity: 0.8;
        transition: var(--transition);
    }

    .nav-links a:hover {
        opacity: 1;
        color: var(--primary-orange);
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .cart-btn {
        position: relative;
        background: none;
        border: none;
        color: var(--white);
        cursor: pointer;
        font-size: 1.2rem;
        display: flex;
        align-items: center;
    }

    .cart-count {
        position: absolute;
        top: -8px;
        right: -8px;
        background-color: var(--primary-orange);
        color: white;
        font-size: 0.7rem;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        font-weight: 700;
    }

    /* Logged In State Elements */
    .wishlist-btn {
        background: none;
        border: none;
        color: var(--white);
        cursor: pointer;
        font-size: 1.3rem;
        display: flex;
        align-items: center;
        transition: var(--transition);
    }

    .wishlist-btn:hover {
        color: #ff4757;
    }

    .profile-avatar {
        width: 38px;
        /* Increased from 30px */
        height: 38px;
        border-radius: 50%;
        border: 2px solid var(--primary-orange);
        cursor: pointer;
        overflow: hidden;
        transition: var(--transition);
    }

    .profile-avatar:hover {
        transform: scale(1.1);
    }

    .profile-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .logout-btn {
        background: rgba(255, 255, 255, 0.1);
        color: white;
        padding: 0.6rem 1.2rem;
        border-radius: 8px;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 600;
        transition: var(--transition);
    }

    .logout-btn:hover {
        background: #ff4757;
        color: white;
    }
</style>

<header id="main-header" class="flex items-center justify-between">
    <a href="landing.html" class="logo">
        <img src="/public/public/logo-icon.png" alt="ZiGo Icon" class="icon">
        <img src="/public/public/logo-name.png" alt="ZiGo" class="name">
    </a>
    <ul class="nav-links hidden lg:flex">
        <li><a href="landing.html">Home</a></li>
        <li><a href="shop.html">Shop</a></li>
        <li><a href="../user/orders.html">Orders</a></li>
        <li><a href="../user/about.html">About</a></li>
        <li><a href="../user/contact.html">Contact</a></li>
    </ul>
    <div class="header-actions flex items-center gap-6">
        <button class="cart-btn">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <circle cx="9" cy="21" r="1"></circle>
                <circle cx="20" cy="21" r="1"></circle>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
            </svg>
            <span class="cart-count">
                <%= (typeof cartCount !=='undefined' && cartCount) ? cartCount : 0 %>
            </span>
        </button>

        <!-- Wishlist -->
        <button class="wishlist-btn hidden sm:block">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path
                    d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l8.82-8.82 1.06-1.06a5.5 5.5 0 0 0 0-7.78z">
                </path>
            </svg>
        </button>

        <!-- Profile and Logout -->
        <div class="hidden sm:flex items-center gap-4">
            <a href="/user/profile" class="profile-avatar">
                <img src="https://ui-avatars.com/api/?name=Fayas&background=FF5A1F&color=fff" alt="User">
            </a>
            <a href="/logout" class="logout-btn">Logout</a>
        </div>

        <button class="lg:hidden text-white">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
        </button>
    </div>
</header>

<script>
    // Header Scroll Effect
    window.addEventListener('scroll', () => {
        const header = document.getElementById('main-header');
        if (window.scrollY > 50) {
            header.classList.add('scrolled');
        } else {
            header.classList.remove('scrolled');
        }
    });
</script>
<style>
    :root {
        --primary-orange: #FF5A1F;
        --primary-orange-hover: #E44D18;
        --deep-black: #0F0F0F;
        --off-white: #F9F9F9;
        --dark-navy: #1E293B;
        --gray-light: #E2E8F0;
        --white: #FFFFFF;
        --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* --- Header --- */
    header {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.92rem 5%;
        /* Final calibration (+5% more) */
        /* Increased by 10% */
        z-index: 1000;
        transition: var(--transition);
        background-color: rgba(15, 15, 15, 0.7);
        backdrop-filter: blur(8px);
    }

    header.scrolled {
        background-color: rgba(15, 15, 15, 0.95);
        backdrop-filter: blur(10px);
        padding: 0.63rem 5%;
        /* Final calibration (+5% more) */
        /* Increased by 10% from 0.55rem */
        box-shadow: 0 4px 40px rgba(255, 90, 31, 0.4);
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
    }

    .logo img.icon {
        height: 116px;
        /* Final calibration (+5% more) */
        /* Increased by 10% from 100px */
        width: auto;
    }

    .logo img.name {
        height: 81px;
        /* Final calibration (+5% more) */
        /* Increased by 10% from 70px */
        width: auto;
        margin-top: 2px;
        mix-blend-mode: screen;
    }

    .nav-links {
        display: flex;
        gap: 2rem;
        list-style: none;
    }

    .nav-links a {
        color: var(--white);
        text-decoration: none;
        font-weight: 500;
        font-size: 0.95rem;
        opacity: 0.8;
        transition: var(--transition);
    }

    .nav-links a:hover {
        opacity: 1;
        color: var(--primary-orange);
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .cart-btn {
        position: relative;
        background: none;
        border: none;
        color: var(--white);
        cursor: pointer;
        font-size: 1.2rem;
        display: flex;
        align-items: center;
    }

    .cart-count {
        position: absolute;
        top: -8px;
        right: -8px;
        background-color: var(--primary-orange);
        color: white;
        font-size: 0.7rem;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        font-weight: 700;
    }

    .profile-link {
        background-color: var(--primary-orange);
        color: white;
        padding: 0.6rem 1.2rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        transition: var(--transition);
    }

    .signup-link {
        background-color: transparent;
        color: var(--primary-orange);
        border: 1px solid var(--primary-orange);
        padding: 0.6rem 1.2rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: var(--transition);
    }

    .signup-link:hover {
        background-color: var(--primary-orange);
        color: white;
    }

    .profile-link:hover {
        background-color: var(--primary-orange-hover);
        transform: translateY(-2px);
    }
</style>

<header id="main-header" class="flex items-center justify-between">
    <a href="/" class="logo">
        <img src="/public/public/logo-icon.png" alt="ZiGo Icon" class="icon">
        <img src="/public/public/logo-name.png" alt="ZiGo" class="name">
    </a>
    <ul class="nav-links hidden lg:flex">
        <li><a href="/">Home</a></li>
        <li><a href="/shop">Shop</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
    </ul>
    <div class="header-actions flex items-center gap-4">
        <button class="cart-btn">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <circle cx="9" cy="21" r="1"></circle>
                <circle cx="20" cy="21" r="1"></circle>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
            </svg>
            <span class="cart-count">0</span>
        </button>
        <div class="hidden sm:flex items-center gap-3">
            <a href="/login" class="profile-link">Login</a>
            <a href="/signUp" class="signup-link">Sign Up</a>
        </div>
        <button class="lg:hidden text-white ml-2">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
        </button>
    </div>
</header>

<script>
    // Header Scroll Effect
    window.addEventListener('scroll', () => {
        const header = document.getElementById('main-header');
        if (window.scrollY > 50) {
            header.classList.add('scrolled');
        } else {
            header.classList.remove('scrolled');
        }
    });
</script>
<style>
    :root {
        --primary-orange: #FF5A1F;
        --deep-black: #0F0F0F;
        --white: #FFFFFF;
        --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* --- Minimal Header (Updated) --- */
    header.minimal-header {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        display: flex;
        justify-content: flex-start;
        /* Logo to the Left */
        align-items: center;
        padding: 0.7rem 5%;
        /* Final calibration (+5% more) */
        z-index: 1000;
        transition: var(--transition);
        background-color: rgba(15, 15, 15, 0.85);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
    }

    .logo img.icon {
        height: 65px;
        /* Final calibration (+5% more) */
        width: auto;
    }

    .logo img.name {
        height: 33px;
        /* Final calibration (+5% more) */
        width: auto;
        margin-top: 1px;
        mix-blend-mode: screen;
    }

    @media (max-width: 640px) {
        header.minimal-header {
            padding: 0.5rem 5%;
        }

        .logo img.icon {
            height: 50px;
        }

        .logo img.name {
            height: 25px;
        }
    }
</style>

<header class="minimal-header">
    <a href="/" class="logo">
        <img src="/public/public/logo-icon.png" alt="ZiGo Icon" class="icon">
        <img src="/public/public/logo-name.png" alt="ZiGo" class="name">
    </a>
</header>

<%- include('flashAlert') %>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZiGo Admin | Command Center</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="icon" type="image/png" href="/public/public/favicon.png">
    <style>
        :root {
            --primary-orange: #FF5A1F;
            --primary-orange-hover: #E44D18;
            --deep-black: #0F0F0F;
            --dark-navy: #1E293B;
            --off-white: #F9F9F9;
            --gray-light: #E2E8F0;
            --white: #FFFFFF;
            --glass: rgba(255, 255, 255, 0.03);
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--deep-black);
            color: var(--white);
            overflow-x: hidden;
            display: flex;
            min-height: 100vh;
        }

        /* --- Admin Sidebar --- */
        .admin-sidebar {
            width: 280px;
            background: rgba(255, 255, 255, 0.02);
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(255, 255, 255, 0.05);
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            padding: 2rem;
            display: flex;
            flex-direction: column;
            z-index: 1000;
            overflow-y: auto;
        }

        .admin-sidebar::-webkit-scrollbar {
            width: 4px;
        }

        .admin-sidebar::-webkit-scrollbar-thumb {
            background: rgba(255, 90, 31, 0.2);
            border-radius: 10px;
        }

        .admin-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 3rem;
            text-decoration: none;
        }

        .admin-logo img {
            height: 48px;
        }

        .admin-nav {
            flex: 1;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1rem 1.5rem;
            border-radius: 16px;
            color: rgba(255, 255, 255, 0.5);
            text-decoration: none;
            font-weight: 600;
            transition: var(--transition);
            margin-bottom: 0.5rem;
        }

        .nav-item i {
            font-size: 1.1rem;
        }

        .nav-item:hover,
        .nav-item.active {
            background: rgba(255, 90, 31, 0.1);
            color: var(--primary-orange);
        }

        .nav-item.active {
            box-shadow: 0 4px 15px rgba(255, 90, 31, 0.1);
        }

        .logout-btn {
            margin-top: auto;
            color: #FF4757;
            background: rgba(255, 71, 87, 0.05);
        }

        .logout-btn:hover {
            background: #FF4757;
            color: white;
        }

        select {
            cursor: pointer;
            font-family: 'Inter', sans-serif;
        }

        select option {
            background: #FFFFFF;
            color: #000000;
        }

        /* --- Main Content --- */
        .admin-main {
            flex: 1;
            margin-left: 280px;
            padding: 2.5rem 3.5rem;
        }

        .admin-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 3rem;
        }

        .header-title h1 {
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -1px;
        }

        /* --- Stats Grid --- */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.5rem;
            margin-bottom: 3rem;
        }

        .stat-card {
            background: var(--glass);
            border: 1px solid rgba(255, 255, 255, 0.05);
            padding: 1.5rem;
            border-radius: 24px;
            transition: var(--transition);
        }

        .stat-card:hover {
            background: rgba(255, 255, 255, 0.05);
            transform: translateY(-5px);
            border-color: rgba(255, 90, 31, 0.3);
        }

        .stat-icon {
            width: 44px;
            height: 44px;
            background: rgba(255, 90, 31, 0.1);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary-orange);
            margin-bottom: 1rem;
        }

        .stat-value {
            font-size: 1.75rem;
            font-weight: 800;
            margin-bottom: 0.25rem;
        }

        .stat-label {
            font-size: 0.8rem;
            font-weight: 600;
            opacity: 0.4;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* --- Charts Area --- */
        .charts-section {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 1.5rem;
            margin-bottom: 3rem;
        }

        .chart-container {
            background: var(--glass);
            border: 1px solid rgba(255, 255, 255, 0.05);
            padding: 2rem;
            border-radius: 32px;
        }

        /* --- Recent List --- */
        .recent-orders {
            background: var(--glass);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 32px;
            padding: 2rem;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1.5rem;
        }

        .data-table th {
            text-align: left;
            padding: 1rem;
            font-size: 0.75rem;
            text-transform: uppercase;
            opacity: 0.4;
            letter-spacing: 1px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .data-table td {
            padding: 1.25rem 1rem;
            font-size: 0.9rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        }

        .status-pill {
            padding: 4px 12px;
            border-radius: 100px;
            font-size: 0.75rem;
            font-weight: 700;
        }

        .status-pending {
            background: rgba(255, 159, 67, 0.1);
            color: #FF9F43;
        }

        .status-delivered {
            background: rgba(46, 213, 115, 0.1);
            color: #2ED573;
        }

        @media (max-width: 1280px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .charts-section {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
    <!-- Sidebar -->
    <aside class="admin-sidebar">
        <a href="#" class="admin-logo">
            <img src="/public/public/logo-icon.png" alt="ZiGo">
            <img src="/public/public/logo-name.png" alt="ZiGo" style="height: 24px;">
        </a>

        <nav class="admin-nav">
            <a href="/admin/dashboard" class="nav-item active">
                <i class="fas fa-chart-line"></i> Dashboard
            </a>
            <a href="/admin/products" class="nav-item">
                <i class="fas fa-box"></i> Products
            </a>
            <a href="/admin/orders" class="nav-item">
                <i class="fas fa-shopping-cart"></i> Orders
            </a>
            <a href="/admin/users" class="nav-item">
                <i class="fas fa-users"></i> Users
            </a>
            <a href="/admin/categories" class="nav-item">
                <i class="fas fa-tags"></i> Categories
            </a>
            <a href="/admin/coupons" class="nav-item">
                <i class="fas fa-ticket-alt"></i> Coupons
            </a>
            <a href="/admin/banners" class="nav-item">
                <i class="fas fa-image"></i> Banners
            </a>
            <a href="/admin/offers" class="nav-item">
                <i class="fas fa-percent"></i> Offers
            </a>
            <a href="/admin/reports" class="nav-item">
                <i class="fas fa-file-invoice-dollar"></i> Sales Report
            </a>
        </nav>

        <a href="/admin/logout" class="nav-item logout-btn">
            <i class="fas fa-sign-out-alt"></i> Sign Out
        </a>
    </aside>

    <!-- Main Content -->
    <main class="admin-main">
        <header class="admin-header">
            <div class="header-title">
                <p class="text-orange-500 font-bold uppercase tracking-[4px] text-xs mb-1">Overview</p>
                <h1>Command <span class="text-orange-500">Center</span></h1>
            </div>

            <div class="flex items-center gap-6">
                <div class="text-right hidden md:block">
                    <p class="font-bold text-sm">Fayas Admin</p>
                    <p class="text-xs opacity-40">System Architect</p>
                </div>
                <div
                    class="w-12 h-12 rounded-2xl bg-orange-500 flex items-center justify-center text-white font-black text-xl">
                    F
                </div>
            </div>
        </header>

        <!-- Stats Grid -->
        <section class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-wallet"></i></div>
                <p class="stat-value">₹12.4L</p>
                <p class="stat-label">Total Revenue</p>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-shopping-bag"></i></div>
                <p class="stat-value">1,240</p>
                <p class="stat-label">Total Orders</p>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-users"></i></div>
                <p class="stat-value">8,432</p>
                <p class="stat-label">Active Users</p>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-chart-pie"></i></div>
                <p class="stat-value">4.2%</p>
                <p class="stat-label">Conversion</p>
            </div>
        </section>

        <!-- Charts Section -->
        <section class="charts-section">
            <div class="chart-container">
                <h3 class="font-bold mb-6 flex justify-between items-center">
                    Revenue Trends
                    <span class="text-xs opacity-40">Last 7 Days</span>
                </h3>
                <canvas id="revenueChart" height="150"></canvas>
            </div>
            <div class="chart-container">
                <h3 class="font-bold mb-6">Top Categories</h3>
                <canvas id="categoryChart"></canvas>
            </div>
        </section>

        <!-- Recent Orders -->
        <section class="recent-orders">
            <h3 class="font-bold mb-2">Recent Orders</h3>
            <p class="text-xs opacity-40 mb-6">Latest customer transactions from all regions</p>

            <table class="data-table">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Product</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="font-bold">#ZIGO-9921</td>
                        <td>
                            <p class="font-bold">Fayas A.</p>
                            <p class="text-[10px] opacity-40">personal@fayas.com</p>
                        </td>
                        <td>Neo 1 Flagship</td>
                        <td class="font-black">₹82,339</td>
                        <td><span class="status-pill status-delivered">Delivered</span></td>
                        <td><button class="text-xs font-bold text-orange-500">Manage</button></td>
                    </tr>
                    <tr>
                        <td class="font-bold">#ZIGO-9922</td>
                        <td>
                            <p class="font-bold">John Doe</p>
                            <p class="text-[10px] opacity-40">john@example.com</p>
                        </td>
                        <td>Watch S Edition</td>
                        <td class="font-black">₹22,805</td>
                        <td><span class="status-pill status-pending">Pending</span></td>
                        <td><button class="text-xs font-bold text-orange-500">Manage</button></td>
                    </tr>
                </tbody>
            </table>
        </section>
    </main>

    <script>
        // Revenue Chart
        const ctxRev = document.getElementById('revenueChart').getContext('2d');
        new Chart(ctxRev, {
            type: 'line',
            data: {
                labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                datasets: [{
                    label: 'Revenue',
                    data: [12000, 19000, 15000, 25000, 22000, 30000, 45000],
                    borderColor: '#FF5A1F',
                    backgroundColor: 'rgba(255, 90, 31, 0.1)',
                    borderWidth: 4,
                    tension: 0.4,
                    fill: true,
                    pointRadius: 0
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { display: false }, ticks: { color: 'rgba(255,255,255,0.4)' } },
                    y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: 'rgba(255,255,255,0.4)' } }
                }
            }
        });

        // Category Chart
        const ctxCat = document.getElementById('categoryChart').getContext('2d');
        new Chart(ctxCat, {
            type: 'doughnut',
            data: {
                labels: ['Phones', 'Watches', 'Audio'],
                datasets: [{
                    data: [55, 25, 20],
                    backgroundColor: ['#FF5A1F', '#1E293B', '#334155'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'bottom', labels: { color: 'rgba(255,255,255,0.6)', boxWidth: 12, padding: 20 } } }
            }
        });
    </script>
</body>

</html>
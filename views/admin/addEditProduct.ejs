<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZiGo Admin | <%= locals.isEdit ? 'Edit' : 'Add New' %> Product</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="icon" type="image/png" href="/public/public/favicon.png">
    <style>
        :root {
            --primary-orange: #FF5A1F;
            --primary-orange-hover: #E44D18;
            --deep-black: #0F0F0F;
            --white: #FFFFFF;
            --glass: rgba(255, 255, 255, 0.03);
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--deep-black);
            color: var(--white);
            display: flex;
            min-height: 100vh;
        }

        /* --- Sidebar Styles --- */
        .admin-sidebar {
            width: 280px;
            background: rgba(255, 255, 255, 0.02);
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(255, 255, 255, 0.05);
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            padding: 2rem;
            display: flex;
            flex-direction: column;
            z-index: 1000;
            overflow-y: auto;
        }

        .admin-sidebar::-webkit-scrollbar {
            width: 4px;
        }

        .admin-sidebar::-webkit-scrollbar-thumb {
            background: rgba(255, 90, 31, 0.2);
            border-radius: 10px;
        }

        .admin-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 3rem;
            text-decoration: none;
        }

        .admin-logo img {
            height: 48px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1rem 1.5rem;
            border-radius: 16px;
            color: rgba(255, 255, 255, 0.5);
            text-decoration: none;
            font-weight: 600;
            transition: var(--transition);
            margin-bottom: 0.5rem;
        }

        .nav-item:hover,
        .nav-item.active {
            background: rgba(255, 90, 31, 0.1);
            color: var(--primary-orange);
        }

        .nav-item.active {
            box-shadow: 0 4px 15px rgba(255, 90, 31, 0.1);
        }

        .logout-btn {
            margin-top: auto;
            color: #FF4757;
            background: rgba(255, 71, 87, 0.05);
        }

        .admin-main {
            flex: 1;
            margin-left: 280px;
            padding: 2.5rem 3.5rem;
        }

        /* --- Form Styling --- */
        .form-card {
            background: var(--glass);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 32px;
            padding: 3rem;
            max-width: 1000px;
            margin: 0 auto;
        }

        .form-group {
            margin-bottom: 2rem;
        }

        .form-label {
            display: block;
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            opacity: 0.4;
            margin-bottom: 0.75rem;
        }

        .form-input {
            width: 100%;
            padding: 1.2rem 1.5rem;
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            background: rgba(255, 255, 255, 0.02);
            color: white;
            font-weight: 600;
            outline: none;
            transition: var(--transition);
            font-family: 'Inter', sans-serif;
        }

        .form-input:focus {
            border-color: var(--primary-orange);
            background: rgba(255, 90, 31, 0.05);
        }

        select.form-input option {
            background: #FFFFFF;
            color: #000000;
            font-weight: 500;
        }

        .image-upload-box {
            border: 2px dashed rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            padding: 3rem;
            text-align: center;
            cursor: pointer;
            transition: 0.3s;
        }

        .image-upload-box:hover {
            border-color: var(--primary-orange);
            background: rgba(255, 90, 31, 0.02);
        }

        .btn-submit {
            background: var(--primary-orange);
            color: white;
            padding: 1.2rem 3rem;
            border-radius: 16px;
            font-weight: 800;
            font-size: 1rem;
            cursor: pointer;
            border: none;
            transition: var(--transition);
        }

        .btn-submit:hover {
            background: var(--primary-orange-hover);
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(255, 90, 31, 0.2);
        }

        .variant-box {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 16px;
            padding: 1.5rem;
            border: 1px solid rgba(255, 255, 255, 0.05);
            margin-bottom: 1rem;
        }
    </style>
</head>

<body>
    <aside class="admin-sidebar">
        <a href="/admin/dashbord" class="admin-logo">
            <img src="/public/public/logo-icon.png" alt="ZiGo">
            <img src="/public/public/logo-name.png" alt="ZiGo" style="height: 24px;">
        </a>
        <nav class="admin-nav">
            <a href="/admin/dashbord" class="nav-item">
                <i class="fas fa-chart-line"></i> Dashboard
            </a>
            <a href="/admin/products" class="nav-item active">
                <i class="fas fa-box"></i> Products
            </a>
            <a href="/admin/orders" class="nav-item">
                <i class="fas fa-shopping-cart"></i> Orders
            </a>
            <a href="/admin/users" class="nav-item">
                <i class="fas fa-users"></i> Users
            </a>
            <a href="/admin/category" class="nav-item">
                <i class="fas fa-tags"></i> Categories
            </a>
            <a href="/admin/coupons" class="nav-item">
                <i class="fas fa-ticket-alt"></i> Coupons
            </a>
            <a href="/admin/banners" class="nav-item">
                <i class="fas fa-image"></i> Banners
            </a>
            <a href="/admin/offers" class="nav-item">
                <i class="fas fa-percent"></i> Offers
            </a>
            <a href="/admin/reports" class="nav-item">
                <i class="fas fa-file-invoice-dollar"></i> Sales Report
            </a>
        </nav>
        <a href="/admin/logout" class="nav-item logout-btn">
            <i class="fas fa-sign-out-alt"></i> Sign Out
        </a>
    </aside>

    <main class="admin-main">
        <header class="mb-12">
            <a href="/admin/products"
                class="text-xs font-bold opacity-40 uppercase tracking-widest hover:text-orange-500 transition mb-4 inline-block">
                <i class="fas fa-arrow-left mr-2"></i> Back to Catalog
            </a>
            <h1 class="text-4xl font-black">
                <%= locals.isEdit ? 'Update' : 'Add New' %> <span class="text-orange-500">Product</span>
            </h1>
        </header>

        <form class="form-card"
            action="<%= locals.isEdit ? '/admin/products/edit/' + product._id : '/admin/products/add' %>" method="POST"
            enctype="multipart/form-data">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Left Column -->
                <div class="space-y-6">
                    <div class="form-group">
                        <label class="form-label">Product Name</label>
                        <input type="text" name="name" class="form-input" placeholder="e.g. ZiGo Neo 2 Pro"
                            value="<%= locals.isEdit ? product.name : '' %>" required>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div class="form-group">
                            <label class="form-label">Category</label>
                            <select name="category" class="form-input">
                                <% locals.categories && categories.forEach(cat=> { %>
                                    <option value="<%= cat._id %>" <%=(locals.isEdit &&
                                        product.category.toString()===cat._id.toString()) ? 'selected' : '' %>><%=
                                            cat.name %>
                                    </option>
                                    <% }) %>
                                        <% if (!locals.categories) { %>
                                            <option>SmartPhone</option>
                                            <option>Watches</option>
                                            <option>Headset</option>
                                            <option>PowerBank</option>
                                            <% } %>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Brand</label>
                            <input type="text" name="brand" class="form-input"
                                value="<%= locals.isEdit ? product.brand : 'ZiGo' %>">
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Full Description</label>
                        <textarea name="description" class="form-input h-48" style="resize: none;"
                            placeholder="Enter product details, specs, etc."><%= locals.isEdit ? product.description : '' %></textarea>
                    </div>
                </div>

                <!-- Right Column -->
                <div class="space-y-6">
                    <div class="form-group">
                        <label class="form-label">Pricing & Inventory</label>
                        <div class="grid grid-cols-2 gap-4">
                            <input type="number" name="price" class="form-input" placeholder="Base Price (₹)"
                                value="<%= locals.isEdit ? product.price : '' %>" required>
                            <input type="number" name="stock" class="form-input" placeholder="Stock Quantity"
                                value="<%= locals.isEdit ? product.stock : '' %>" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Product Images</label>
                        <div class="image-upload-box" onclick="document.getElementById('imageInput').click()">
                            <i class="fas fa-cloud-upload-alt text-4xl text-orange-500 mb-4"></i>
                            <p class="font-bold text-sm">Drop your images here or <span
                                    class="text-orange-500">browse</span></p>
                            <p class="text-[10px] opacity-40 mt-2">Supports JPG, PNG, WEBP (Max 5MB per image)</p>
                            <input type="file" name="images" id="imageInput" class="hidden" multiple accept="image/*">
                        </div>
                        <div id="imagePreviewContainer" class="grid grid-cols-4 gap-2 mt-4">
                            <% if (locals.isEdit && product.images) { %>
                                <% product.images.forEach(img=> { %>
                                    <div class="relative group">
                                        <img src="/uploads/products/<%= img %>"
                                            class="w-full h-20 object-cover rounded-lg">
                                        <button type="button"
                                            class="absolute -top-2 -right-2 bg-red-500 text-white rounded-full p-1 opacity-0 group-hover:opacity-100 transition"><i
                                                class="fas fa-times"></i></button>
                                    </div>
                                    <% }) %>
                                        <% } %>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Variants (Simulated)</label>
                        <div class="variant-box">
                            <div class="flex justify-between items-center mb-4">
                                <span class="text-sm font-bold">Storage / RAM</span>
                                <button type="button" class="text-orange-500 font-bold text-xs">+ Add Variant</button>
                            </div>
                            <div class="flex gap-2">
                                <span class="bg-white/10 px-3 py-1 rounded-lg text-xs font-bold">8GB / 256GB</span>
                                <span class="bg-white/10 px-3 py-1 rounded-lg text-xs font-bold">12GB / 512GB</span>
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center gap-4 bg-white/5 p-6 rounded-2xl border border-white/5">
                        <label class="relative inline-flex items-center cursor-pointer group">
                            <input type="checkbox" name="isListed" <%=(locals.isEdit && !product.isListed) ? ''
                                : 'checked' %> class="sr-only peer">
                            <div
                                class="w-11 h-6 bg-white/10 rounded-full peer peer-checked:bg-orange-500 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-full">
                            </div>
                        </label>
                        <div>
                            <p class="font-bold text-sm" id="statusLabel">
                                <%= (locals.isEdit && !product.isListed) ? 'Save as Draft' : 'List Product Immediately'
                                    %>
                            </p>
                            <p class="text-[10px] opacity-40 font-bold uppercase tracking-widest" id="visibilityLabel">
                                Visibility: <%= (locals.isEdit && !product.isListed) ? 'Private' : 'Public' %>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-12 pt-8 border-t border-white/5 flex justify-end gap-4">
                <button type="button" onclick="window.history.back()"
                    class="bg-white/5 text-white font-bold px-8 py-4 rounded-16 hover:bg-white/10 transition">Cancel</button>
                <button type="submit" class="btn-submit">
                    <%= locals.isEdit ? 'Update Product' : 'Publish Product' %>
                </button>
            </div>
        </form>
    </main>

    <script>
        const imageInput = document.getElementById('imageInput');
        const previewContainer = document.getElementById('imagePreviewContainer');
        const listToggle = document.querySelector('input[name="isListed"]');
        const statusLabel = document.getElementById('statusLabel');
        const visibilityLabel = document.getElementById('visibilityLabel');

        imageInput.addEventListener('change', (e) => {
            const files = Array.from(e.target.files);
            // In a real implementation, you might want to show previews here
            console.log(`${files.length} images selected`);
        });

        listToggle.addEventListener('change', (e) => {
            if (e.target.checked) {
                statusLabel.innerText = 'List Product Immediately';
                visibilityLabel.innerText = 'Visibility: Public';
            } else {
                statusLabel.innerText = 'Save as Draft';
                visibilityLabel.innerText = 'Visibility: Private';
            }
        });
    </script>
</body>

</html>
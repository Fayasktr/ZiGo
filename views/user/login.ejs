<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZiGo | Login</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="icon" type="image/png" href="/public/public/favicon.png">
    <style>
        :root {
            --primary-orange: #FF5A1F;
            --primary-orange-hover: #E44D18;
            --deep-black: #0F0F0F;
            --off-white: #F9F9F9;
            --dark-navy: #1E293B;
            --gray-light: #E2E8F0;
            --white: #FFFFFF;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--deep-black);
            color: var(--white);
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* --- Global Header --- */
        header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.28rem 5%;
            z-index: 1000;
            transition: var(--transition);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .logo img.icon {
            height: 95px;
            width: auto;
        }

        .logo img.name {
            height: 47px;
            width: auto;
            margin-top: 2px;
        }

        /* --- Login Section --- */
        .login-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: var(--deep-black);
            padding: 2rem;
            position: relative;
            padding-top: 100px;
        }

        .login-container::before {
            content: '';
            position: absolute;
            width: 1000px;
            height: 1000px;
            background: radial-gradient(circle, rgba(255, 90, 31, 0.1) 0%, transparent 70%);
            top: -500px;
            right: -500px;
            z-index: 1;
        }

        .login-card {
            width: 100%;
            max-width: 1100px;
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 32px;
            display: flex;
            overflow: hidden;
            z-index: 2;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .login-card.active {
            opacity: 1;
            transform: translateY(0);
        }

        .login-visual {
            flex: 1.2;
            background: url('/public/login/login-bg.png') center/cover no-repeat;
            display: none;
            position: relative;
        }

        .login-visual::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to right, rgba(15, 15, 15, 0.9), transparent);
        }

        @media (min-width: 1024px) {
            .login-visual {
                display: block;
            }
        }

        .login-form-side {
            flex: 1;
            padding: 3.5rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .login-header h2 {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            background: linear-gradient(to right, #fff, var(--primary-orange));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .login-header p {
            opacity: 0.6;
            margin-bottom: 2.5rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group label {
            display: block;
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            opacity: 0.8;
        }

        .input-wrapper input {
            width: 100%;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 1rem 1.2rem;
            border-radius: 12px;
            color: white;
            font-size: 1rem;
            outline: none;
            transition: var(--transition);
            margin-top: 5px;
        }

        .input-wrapper input:focus {
            border-color: var(--primary-orange);
            background: rgba(255, 255, 255, 0.1);
            box-shadow: 0 0 0 4px rgba(255, 90, 31, 0.1);
        }

        .forgot-pass {
            display: block;
            text-align: right;
            font-size: 0.85rem;
            color: var(--primary-orange);
            text-decoration: none;
            margin-top: 0.5rem;
            transition: var(--transition);
        }

        .login-btn {
            width: 100%;
            background: var(--primary-orange);
            color: white;
            border: none;
            padding: 1.1rem;
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: var(--transition);
            margin-top: 1.5rem;
        }

        .login-btn:hover {
            background: var(--primary-orange-hover);
            transform: translateY(-2px);
            box-shadow: 0 12px 24px rgba(255, 90, 31, 0.3);
        }

        .social-divider {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin: 2rem 0;
            opacity: 0.3;
        }

        .social-divider::before,
        .social-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: white;
        }

        .social-btn {
            width: 100%;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 0.8rem;
            border-radius: 12px;
            color: white;
            font-weight: 600;
            cursor: pointer;
            margin-bottom: 1rem;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 0.8rem;
            transition: var(--transition);
        }

        .social-btn:hover {
            background: rgba(255, 255, 255, 0.1);
        }

        .signup-link {
            text-align: center;
            margin-top: 2rem;
            opacity: 0.7;
        }

        .signup-link a {
            color: var(--primary-orange);
            text-decoration: none;
            font-weight: 700;
        }

        /* --- Error Alert Styling --- */
        .error-alert {
            background: rgba(239, 68, 68, 0.1);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(239, 68, 68, 0.2);
            padding: 1rem 1.25rem;
            border-radius: 16px;
            color: #ef4444;
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 2rem;
            animation: slideDown 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .error-alert i {
            font-size: 1.1rem;
        }

        .error-alert span {
            font-size: 0.9rem;
            font-weight: 600;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body>
    <header>
        <a href="/" class="logo">
            <img src="/public/public/logo-icon.png" alt="ZiGo Icon" class="icon">
            <img src="/public/public/logo-name.png" alt="ZiGo" class="name">
        </a>
        <ul class="nav-links hidden lg:flex"
            style="display: flex; gap: 2rem; list-style: none; margin-left: auto; margin-right: 2rem;">
            <li><a href="/"
                    style="color: rgb(183, 179, 179); text-decoration: none; font-weight: 500; opacity: 0.8;">Home</a>
            </li>
            <li><a href="/shop" style="color: white; text-decoration: none; font-weight: 500; opacity: 0.8;">Shop</a>
            </li>
            <li><a href="/categories"
                    style="color: white; text-decoration: none; font-weight: 500; opacity: 0.8;">Categories</a>
            </li>
            <li><a href="/orders"
                    style="color: white; text-decoration: none; font-weight: 500; opacity: 0.8;">Orders</a></li>
            <li><a href="/about" style="color: white; text-decoration: none; font-weight: 500; opacity: 0.8;">About</a>
            </li>
            <li><a href="/contact"
                    style="color: white; text-decoration: none; font-weight: 500; opacity: 0.8;">Contact</a></li>
        </ul>
    </header>

    <div class="login-container">
        <div class="login-card" id="loginCard">
            <div class="login-visual">
                <div class="absolute bottom-12 left-12 z-10">
                    <h3 class="text-3xl font-extrabold text-white mb-2">Welcome Back</h3>
                    <p class="text-white/60">Your next tech adventure starts here.</p>
                </div>
            </div>

            <div class="login-form-side">
                <div class="login-header text-center lg:text-left">
                    <h2>Log In</h2>
                    <p style="margin-bottom: 3px;">Enter your details to access your account</p>
                    <% if (locals.error && error.length> 0) { %>
                        <div class="error-alert"
                            style="background: rgba(255, 90, 31, 0.1); border: 1px solid rgba(255, 90, 31, 0.3); color: #ff8b60; padding: 0.8rem 1rem; border-radius: 12px; margin: 1.5rem 0; font-size: 0.9rem; font-weight: 500; display: flex; align-items: center; gap: 0.8rem;">
                            <i class="fas fa-exclamation-circle"></i>
                            <%= error %>
                        </div>
                        <% } %>
                </div>

                <form action="/login" method="POST" id="loginForm" novalidate>
                    <div class="form-group">
                        <label>Email Address</label>
                        <div class="input-wrapper">
                            <input type="email" name="email" id="email" placeholder="name@example.com" value="fayaskpktr@gmail.com">
                        </div>
                        <div id="emailError" style="color: red; font-size: 0.8rem; margin-top: 5px; display: none;">
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Password</label>
                        <div class="input-wrapper" style="position: relative;">
                            <input type="password" id="password" name="password" placeholder="••••••••" value="<%=123456%>"
                                style="padding-right: 40px;">
                            <button type="button" onclick="togglePassword()"
                                style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: white; opacity: 0.7;">
                                <svg id="eye-open" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                    stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                    <circle cx="12" cy="12" r="3"></circle>
                                </svg>
                                <svg id="eye-closed" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                    stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round" style="display: none;">
                                    <path
                                        d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24">
                                    </path>
                                    <line x1="1" y1="1" x2="23" y2="23"></line>
                                </svg>
                            </button>
                        </div>
                        <div id="passwordError" style="color: red; font-size: 0.8rem; margin-top: 5px; display: none;">
                        </div>

                        <a href="/forgotPassword" class="forgot-pass">Forgot Password?</a>
                    </div>

                    <button type="submit" class="login-btn">Sign In to ZiGo</button>
                </form>

                <div class="social-divider">Or continue with</div>

                <div class="flex justify-center">
                    <a href="/auth/google" class="social-btn w-full">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path
                                d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                                fill="#4285F4" />
                            <path
                                d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                                fill="#34A853" />
                            <path
                                d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                                fill="#FBBC05" />
                            <path
                                d="M12 5.38c1.62 0 3.06.56 4.21 1.66l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                                fill="#EA4335" />
                        </svg>
                        Google
                    </a>
                </div>

                <p class="signup-link">
                    New here? <a href="/signup">Create an Account</a>
                </p>
            </div>
        </div>
    </div>

    <script>
        function togglePassword() {
            const passwordInput = document.getElementById("password");
            const eyeOpen = document.getElementById("eye-open");
            const eyeClosed = document.getElementById("eye-closed");

            if (passwordInput.type === "password") {
                passwordInput.type = "text";
                eyeOpen.style.display = "none";
                eyeClosed.style.display = "block";
            } else {
                passwordInput.type = "password";
                eyeOpen.style.display = "block";
                eyeClosed.style.display = "none";
            }
        }

        window.onload = () => {
            document.querySelector('.login-card').classList.add('active');
        }

        const loginForm = document.getElementById('loginForm');
        const emailInput = document.getElementById('email');
        const passwordInput = document.getElementById('password');
        const emailError = document.getElementById('emailError');
        const passwordError = document.getElementById('passwordError');

        loginForm.addEventListener('submit', (e) => {
            let isValid = true;

            emailError.style.display = 'none';
            passwordError.style.display = 'none';
            emailError.textContent = '';
            passwordError.textContent = '';

            const emailValue = emailInput.value.trim();
            const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

            if (!emailValue) {
                emailError.textContent = 'Email address is required';
                emailError.style.display = 'block';
                isValid = false;
            } else if (!emailPattern.test(emailValue)) {
                emailError.textContent = 'Please enter a valid email address';
                emailError.style.display = 'block';
                isValid = false;
            }

            const passwordValue = passwordInput.value.trim();
            if (!passwordValue) {
                passwordError.textContent = 'Password is required';
                passwordError.style.display = 'block';
                isValid = false;
            }

            if (!isValid) {
                e.preventDefault();
            }
        });
    </script>
</body>

</html>
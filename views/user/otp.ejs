<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZiGo | Verify Your Email</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="icon" type="image/png" href="/public/public/favicon.png">
    <style>
        :root {
            --primary-orange: #FF5A1F;
            --primary-orange-hover: #E44D18;
            --deep-black: #0F0F0F;
            --off-white: #F9F9F9;
            --dark-navy: #1E293B;
            --gray-light: #E2E8F0;
            --white: #FFFFFF;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--deep-black);
            color: var(--white);
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* --- Global Header --- */
        header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.5rem 5%;
            z-index: 1000;
            transition: var(--transition);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .logo img.icon {
            height: 95px;
            width: auto;
        }

        .logo img.name {
            height: 47px;
            width: auto;
            margin-top: 2px;
        }

        /* --- OTP Section --- */
        .otp-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: var(--deep-black);
            padding: 2rem;
            position: relative;
            padding-top: 100px;
        }

        .otp-container::before {
            content: '';
            position: absolute;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(255, 90, 31, 0.15) 0%, transparent 70%);
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            z-index: 1;
        }

        .otp-card {
            width: 100%;
            max-width: 500px;
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 32px;
            padding: 4rem 3rem;
            text-align: center;
            z-index: 2;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .otp-card.active {
            opacity: 1;
            transform: translateY(0);
        }

        .otp-header {
            margin-bottom: 2.5rem;
        }

        .otp-header .icon-box {
            width: 80px;
            height: 80px;
            background: rgba(255, 90, 31, 0.1);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            color: var(--primary-orange);
            font-size: 2rem;
        }

        .otp-header h2 {
            font-size: 2.2rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            background: linear-gradient(to right, #fff, var(--primary-orange));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .otp-header p {
            opacity: 0.6;
            font-size: 0.95rem;
            line-height: 1.5;
        }

        .otp-inputs {
            display: flex;
            gap: 1rem;
            justify-content: center;
            margin-bottom: 2.5rem;
        }

        .otp-field {
            width: 65px;
            height: 75px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            font-size: 1.8rem;
            font-weight: 700;
            color: white;
            text-align: center;
            outline: none;
            transition: var(--transition);
        }

        .otp-field:focus {
            border-color: var(--primary-orange);
            background: rgba(255, 255, 255, 0.08);
            box-shadow: 0 0 0 4px rgba(255, 90, 31, 0.1);
        }

        .verify-btn {
            width: 100%;
            background: var(--primary-orange);
            color: white;
            border: none;
            padding: 1.2rem;
            border-radius: 14px;
            font-size: 1.1rem;
            font-weight: 700;
            cursor: pointer;
            transition: var(--transition);
            margin-bottom: 2rem;
        }

        .verify-btn:hover {
            background: var(--primary-orange-hover);
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(255, 90, 31, 0.3);
        }

        .resend-text {
            font-size: 0.95rem;
            opacity: 0.7;
        }

        .resend-link {
            color: var(--primary-orange);
            text-decoration: none;
            font-weight: 700;
            margin-left: 0.25rem;
        }

        .resend-link.disabled {
            opacity: 0.5;
            cursor: not-allowed;
            pointer-events: none;
        }

        #timer {
            font-weight: 700;
            color: var(--primary-orange);
        }

        .hidden {
            display: none;
        }
    </style>
</head>

<body>
    <header>
        <a href="/" class="logo">
            <img src="/public/public/logo-icon.png" alt="ZiGo Icon" class="icon">
            <img src="/public/public/logo-name.png" alt="ZiGo" class="name">
        </a>
    </header>

    <div class="otp-container">
        <div class="otp-card" id="otpCard">
            <div class="otp-header">
                <div class="icon-box">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <h2>Verify Email</h2>
                <p>We've sent a 4-digit code to your email.<br>Please enter it below to verify your account.</p>
                <% if (locals.error) { %>
                    <div
                        style="background: rgba(255, 0, 0, 0.1); color: #ff4444; padding: 10px; border-radius: 8px; margin-top: 10px; font-weight: 600;">
                        <%= error %>
                    </div>
                    <% } %>
            </div>

            <form id="otpForm" action="/verifyOtp" method="POST">
                <div class="otp-inputs">
                    <input type="text" class="otp-field" maxlength="1" pattern="\d" required>
                    <input type="text" class="otp-field" maxlength="1" pattern="\d" required>
                    <input type="text" class="otp-field" maxlength="1" pattern="\d" required>
                    <input type="text" class="otp-field" maxlength="1" pattern="\d" required>
                </div>
                <input type="hidden" name="otp" id="full-otp">
                <input type="hidden" name="userId" value="<%= locals.userId || '' %>">

                <button type="submit" class="verify-btn">Verify & Activate</button>
            </form>

            <p class="resend-text">
                Didn't receive the code?
                <span id="timerBox">Resend in <span id="timer">01:00s</span></span>
                <a href="/resend-otp" class="resend-link disabled" id="resendBtn">Resend New Code</a>
            </p>
        </div>
    </div>

    <script>
        window.onload = () => {
            document.getElementById('otpCard').classList.add('active');
            // Focus first field
            fields[0].focus();
        }

        const fields = document.querySelectorAll('.otp-field');
        const form = document.getElementById('otpForm');
        const fullOtpInput = document.getElementById('full-otp');

        fields.forEach((field, index) => {
            field.addEventListener('input', (e) => {
                if (e.target.value.length === 1 && index < fields.length - 1) {
                    fields[index + 1].focus();
                }
                updateFullOtp();
            });

            field.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && !e.target.value && index > 0) {
                    fields[index - 1].focus();
                }
            });
        });

        function updateFullOtp() {
            let otp = '';
            fields.forEach(field => otp += field.value);
            fullOtpInput.value = otp;
        }

        form.addEventListener('submit', (e) => {
            updateFullOtp();
            if (fullOtpInput.value.length !== 4) {
                e.preventDefault();
                alert('Please enter a valid 4-digit OTP');
            }
        });

        // Timer logic
        let timeLeft = 300;
        const timerDisplay = document.getElementById('timer');
        const timerBox = document.getElementById('timerBox');
        const resendBtn = document.getElementById('resendBtn');

        const countdown = setInterval(() => {
            timeLeft--;
            const mins = Math.floor(timeLeft / 60);
            const secs = timeLeft % 60;
            timerDisplay.textContent = `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}s`;

            if (timeLeft <= 0) {
                clearInterval(countdown);
                timerBox.classList.add('hidden');
                resendBtn.classList.remove('disabled');
            }
        }, 1000);
    </script>
</body>

</html>
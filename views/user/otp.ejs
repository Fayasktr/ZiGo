<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZiGo | Verify Your Email</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="icon" type="image/png" href="/public/public/favicon.png">
    <style>
        :root {
            --primary-orange: #FF5A1F;
            --primary-orange-hover: #E44D18;
            --deep-black: #0F0F0F;
            --off-white: #F9F9F9;
            --dark-navy: #1E293B;
            --gray-light: #E2E8F0;
            --white: #FFFFFF;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--deep-black);
            color: var(--white);
            overflow-x: hidden;
            line-height: 1.6;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* --- Global Header --- */
        header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.5rem 5%;
            z-index: 1000;
            transition: var(--transition);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .logo img.icon {
            height: 95px;
            width: auto;
        }

        .logo img.name {
            height: 47px;
            width: auto;
            margin-top: 2px;
        }

        /* --- OTP Section --- */
        .otp-container {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: var(--deep-black);
            padding: 2rem;
            position: relative;
            z-index: 1;
        }

        .glow {
            position: absolute;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(255, 90, 31, 0.08) 0%, transparent 70%);
            z-index: -1;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

        .glow-2 {
            top: 10%;
            left: 80%;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(255, 90, 31, 0.05) 0%, transparent 70%);
        }

        .otp-card {
            width: 100%;
            max-width: 500px;
            background: rgba(255, 255, 255, 0.02);
            backdrop-filter: blur(30px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 40px;
            padding: 4rem 3rem;
            text-align: center;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .otp-card.active {
            opacity: 1;
            transform: translateY(0);
        }

        .otp-header {
            margin-bottom: 2.5rem;
        }

        .otp-header .icon-box {
            width: 80px;
            height: 80px;
            background: rgba(255, 90, 31, 0.1);
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            color: var(--primary-orange);
            font-size: 2rem;
            box-shadow: 0 8px 16px -4px rgba(255, 90, 31, 0.2);
        }

        .otp-header h2 {
            font-size: 2.4rem;
            font-weight: 900;
            margin-bottom: 0.75rem;
            background: linear-gradient(135deg, #fff 0%, rgba(255, 255, 255, 0.5) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -1px;
        }

        .otp-header p {
            color: rgba(255, 255, 255, 0.5);
            font-size: 0.95rem;
            line-height: 1.6;
            max-width: 80%;
            margin: 0 auto;
        }

        .otp-inputs {
            display: flex;
            gap: 1.25rem;
            justify-content: center;
            margin-bottom: 2.5rem;
        }

        .otp-field {
            width: 65px;
            height: 75px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 18px;
            font-size: 2rem;
            font-weight: 800;
            color: white;
            text-align: center;
            outline: none;
            transition: var(--transition);
        }

        .otp-field:focus {
            border-color: var(--primary-orange);
            background: rgba(255, 255, 255, 0.05);
            box-shadow: 0 0 0 5px rgba(255, 90, 31, 0.15);
            transform: translateY(-2px);
        }

        .verify-btn {
            width: 100%;
            background: var(--primary-orange);
            color: white;
            border: none;
            padding: 1.25rem;
            border-radius: 18px;
            font-size: 1.1rem;
            font-weight: 800;
            cursor: pointer;
            transition: var(--transition);
            margin-bottom: 2rem;
            box-shadow: 0 10px 20px -5px rgba(255, 90, 31, 0.4);
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .verify-btn:hover {
            background: var(--primary-orange-hover);
            transform: translateY(-2px);
            box-shadow: 0 15px 30px -5px rgba(255, 90, 31, 0.5);
        }

        .verify-btn:active {
            transform: translateY(0);
        }

        .resend-text {
            font-size: 0.95rem;
            color: rgba(255, 255, 255, 0.4);
        }

        .resend-link {
            color: var(--primary-orange);
            text-decoration: none;
            font-weight: 700;
            margin-left: 0.5rem;
            transition: var(--transition);
        }

        .resend-link:hover {
            opacity: 0.8;
            text-decoration: underline;
        }

        .resend-link.disabled {
            opacity: 0.3;
            cursor: not-allowed;
            pointer-events: none;
            text-decoration: none;
        }

        #timer {
            font-weight: 800;
            color: white;
            margin-left: 4px;
        }

        .error-toast {
            background: rgba(255, 68, 68, 0.1);
            color: #ff4444;
            padding: 1rem;
            border-radius: 16px;
            margin-top: 1.5rem;
            font-weight: 600;
            font-size: 0.9rem;
            border: 1px solid rgba(255, 68, 68, 0.2);
            animation: shake 0.5s ease-in-out;
        }

        @keyframes shake {

            0%,
            100% {
                transform: translateX(0);
            }

            25% {
                transform: translateX(-5px);
            }

            75% {
                transform: translateX(5px);
            }
        }

        .hidden {
            display: none;
        }
    </style>
</head>

<body>
    <header>
        <a href="/" class="logo">
            <img src="/public/public/logo-icon.png" alt="ZiGo Icon" class="icon">
            <img src="/public/public/logo-name.png" alt="ZiGo" class="name">
        </a>
    </header>

    <div class="otp-container">
        <div class="glow"></div>
        <div class="glow glow-2"></div>

        <div class="otp-card" id="otpCard">
            <div class="otp-header">
                <div class="icon-box">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <h2>Verify Email</h2>
                <p>We've sent a 4-digit code to your email. Enter it below to secure your account.</p>
                <% if (error && error.length> 0) { %>
                    <div class="error-toast">
                        <i class="fas fa-exclamation-circle mr-2"></i>
                        <%= error %>
                    </div>
                    <% } %>
                <div id="clientError" class="error-toast hidden">
                    <i class="fas fa-exclamation-circle mr-2"></i>
                    <span id="clientErrorMessage">only numbers allow..</span>
                </div>
            </div>

            <form id="otpForm" action="<%= locals.verifyAction || '/verifyOtp' %>" method="POST">
                <div class="otp-inputs">
                    <input type="text" class="otp-field otp-input" maxlength="1" pattern="\d" required
                        autocomplete="one-time-code">
                    <input type="text" class="otp-field otp-input" maxlength="1" pattern="\d" required>
                    <input type="text" class="otp-field otp-input" maxlength="1" pattern="\d" required>
                    <input type="text" class="otp-field otp-input" maxlength="1" pattern="\d" required>
                </div>
                <input type="hidden" name="otp" id="full-otp">
                <input type="hidden" name="userId" value="<%= locals.userId || '' %>">

                <button type="submit" class="verify-btn">Verify Account</button>
            </form>

            <span id="timerBox">Resend in <span id="timer">01:00</span></span>
            <a href="<%= locals.resendAction || '/resendOtp' %>" class="resend-link disabled" id="resendBtn">Resend
                Code</a>
        </div>
    </div>

    <script>
        const inputs = document.querySelectorAll('.otp-input');
        const form = document.getElementById('otpForm');
        const fullOtpInput = document.getElementById('full-otp');
        const timerDisplay = document.getElementById('timer');
        const resendBtn = document.getElementById('resendBtn');
        const timerBox = document.getElementById('timerBox');

        // --- PASTE LOGIC ---
        inputs[0].addEventListener("paste", (event) => {
            event.preventDefault();
            const pasteData = event.clipboardData.getData("text");
            const clientError = document.getElementById('clientError');

            if (/[^0-9]/.test(pasteData)) {
                clientError.classList.remove('hidden');
                setTimeout(() => {
                    clientError.classList.add('hidden');
                }, 2000);
            }

            const otpArray = pasteData.replace(/[^0-9]/g, '').split('');
            otpArray.forEach((char, index) => {
                if (inputs[index]) {
                    inputs[index].value = char;
                }
            });

            const nextFocusIndex = Math.min(otpArray.length, inputs.length - 1);
            if (inputs[nextFocusIndex]) inputs[nextFocusIndex].focus();
            updateFullOtp();
        });

        // --- TIMER LOGIC ---
        let timeLeft;
        let countdown;

        function startTimer() {
            resendBtn.classList.add('disabled');
            timerBox.classList.remove('hidden');

            // Calculate initial time left in seconds
            const expiryTime = Number("<%=otpTime%>");
            const currentTime = Date.now();
            timeLeft = Math.max(0, Math.floor((expiryTime - currentTime) / 1000));

            updateTimerDisplay();

            clearInterval(countdown);
            countdown = setInterval(() => {
                timeLeft--;

                if (timeLeft <= 0) {
                    clearInterval(countdown);
                    timeLeft = 0;
                    updateTimerDisplay();
                    timerBox.classList.add('hidden');
                    resendBtn.classList.remove('disabled');
                } else {
                    updateTimerDisplay();
                }
            }, 1000);
        }

        function updateTimerDisplay() {
            const mins = Math.floor(timeLeft / 60);
            const secs = timeLeft % 60;
            timerDisplay.textContent = `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
        }

        inputs.forEach((input, index) => {
            input.addEventListener('input', (e) => {
                const val = e.target.value;
                const clientError = document.getElementById('clientError');
                
                // Allow only numbers
                if (val && !/^\d$/.test(val)) {
                    e.target.value = '';
                    clientError.classList.remove('hidden');
                    setTimeout(() => {
                        clientError.classList.add('hidden');
                    }, 2000);
                    return;
                }

                if (val.length == 1 && index < inputs.length - 1) {
                    inputs[index + 1].focus();
                }
                updateFullOtp();
            });

            input.addEventListener('keydown', (e) => {
                if (e.key == 'Backspace' && !e.target.value && index > 0) {
                    inputs[index - 1].focus();
                }
            });
        });

        function updateFullOtp() {
            let otp = '';
            inputs.forEach(input => otp += input.value);
            fullOtpInput.value = otp;
        }

        form.addEventListener('submit', (e) => {
            updateFullOtp();
            if (fullOtpInput.value.length != inputs.length) {
                e.preventDefault();
            }
        });

        window.onload = () => {
            document.getElementById('otpCard').classList.add('active');
            inputs[0].focus();
            startTimer();
        };
    </script>
</body>

</html>
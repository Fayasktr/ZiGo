<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZiGo | Forgot Password</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="icon" type="image/png" href="/public/public/favicon.png">
    <style>
        :root {
            --primary-orange: #FF5A1F;
            --primary-orange-hover: #E44D18;
            --deep-black: #0F0F0F;
            --off-white: #F9F9F9;
            --dark-navy: #1E293B;
            --gray-light: #E2E8F0;
            --white: #FFFFFF;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--deep-black);
            color: var(--white);
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* --- Global Header --- */
        header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.28rem 5%;
            z-index: 1000;
            transition: var(--transition);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .logo img.icon {
            height: 95px;
            width: auto;
        }

        .logo img.name {
            height: 47px;
            width: auto;
            margin-top: 2px;
        }

        /* --- Forgot PW Section --- */
        .forgot-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: var(--deep-black);
            padding: 2rem;
            position: relative;
            padding-top: 100px;
        }

        .forgot-container::before {
            content: '';
            position: absolute;
            width: 1000px;
            height: 1000px;
            background: radial-gradient(circle, rgba(255, 90, 31, 0.1) 0%, transparent 70%);
            top: -500px;
            right: -500px;
            z-index: 1;
        }

        .forgot-card {
            width: 100%;
            max-width: 1100px;
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 32px;
            display: flex;
            overflow: hidden;
            z-index: 2;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .forgot-card.active {
            opacity: 1;
            transform: translateY(0);
        }

        .forgot-visual {
            flex: 1;
            background: url('/public/login/login-bg.png') center/cover no-repeat;
            display: none;
            position: relative;
        }

        .forgot-visual::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to right, rgba(15, 15, 15, 0.8), transparent);
        }

        @media (min-width: 1024px) {
            .forgot-visual {
                display: block;
            }
        }

        .forgot-form-side {
            flex: 1;
            padding: 4rem 3.5rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .forgot-header h2 {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 0.8rem;
            background: linear-gradient(to right, #fff, var(--primary-orange));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .forgot-header p {
            opacity: 0.6;
            margin-bottom: 2.5rem;
            font-size: 1rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group label {
            display: block;
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            opacity: 0.8;
        }

        .input-wrapper input {
            width: 100%;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 1.1rem 1.4rem;
            border-radius: 14px;
            color: white;
            font-size: 1rem;
            outline: none;
            transition: var(--transition);
        }

        .input-wrapper input:focus {
            border-color: var(--primary-orange);
            background: rgba(255, 255, 255, 0.08);
            box-shadow: 0 0 0 4px rgba(255, 90, 31, 0.1);
        }

        .submit-btn {
            width: 100%;
            background: var(--primary-orange);
            color: white;
            border: none;
            padding: 1.2rem;
            border-radius: 14px;
            font-size: 1.1rem;
            font-weight: 700;
            cursor: pointer;
            transition: var(--transition);
            margin-top: 1rem;
        }

        .submit-btn:hover {
            background: var(--primary-orange-hover);
            transform: translateY(-2px);
            box-shadow: 0 12px 24px rgba(255, 90, 31, 0.3);
        }

        .back-to-login {
            text-align: center;
            margin-top: 2rem;
            opacity: 0.7;
            font-size: 0.95rem;
        }

        .back-to-login a {
            color: var(--primary-orange);
            text-decoration: none;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .back-to-login a:hover {
            text-decoration: underline;
        }

        /* --- Footer --- */
        footer {
            background-color: #080808;
            padding: 5rem 5% 2rem;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            margin-top: auto;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 4rem;
        }

        .footer-col h4 {
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 2rem;
        }

        .footer-links {
            list-style: none;
        }

        .footer-links li {
            margin-bottom: 1rem;
        }

        .footer-links a {
            color: white;
            text-decoration: none;
            opacity: 0.6;
            transition: var(--transition);
        }

        .footer-links a:hover {
            opacity: 1;
            color: var(--primary-orange);
        }
    </style>
</head>

<body>
    <header>
        <a href="/" class="logo">
            <img src="/public/public/logo-icon.png" alt="ZiGo Icon" class="icon">
            <img src="/public/public/logo-name.png" alt="ZiGo" class="name">
        </a>
    </header>

    <div class="forgot-container">
        <div class="forgot-card" id="forgotCard">
            <div class="forgot-visual">
                <div class="absolute bottom-12 left-12 z-10">
                    <h3 class="text-3xl font-extrabold text-white mb-2">Secure Your Account</h3>
                    <p class="text-white/60">We'll help you get back into ZiGo.</p>
                </div>
            </div>

            <div class="forgot-form-side">
                <div class="forgot-header">
                    <h2>Forgot Password?</h2>
                    <p>No worries, it happens. Enter your email address and we'll send you a link to reset your
                        password.</p>
                    <% if (locals.error && error.length> 0) { %>
                        <div style="color: red; font-size: 0.9rem; margin-bottom: 15px;">
                            <%= error %>
                        </div>
                        <% } %>
                            <% if (locals.success && success.length> 0) { %>
                                <div style="color: #4BB543; font-size: 0.9rem; margin-bottom: 15px;">
                                    <%= success %>
                                </div>
                                <% } %>
                </div>

                <form action="/forgotPassword" method="POST">
                    <div class="form-group">
                        <label>Email Address</label>
                        <div class="input-wrapper">
                            <input type="email" name="email" placeholder="name@example.com" required>
                        </div>
                    </div>

                    <button type="submit" class="submit-btn">Send Reset Link</button>
                </form>

                <p class="back-to-login">
                    <a href="/login">
                        <i class="fas fa-arrow-left"></i>
                        Back to Login
                    </a>
                </p>
            </div>
        </div>
    </div>

    <footer>
        <div class="footer-grid max-w-7xl mx-auto">
            <div class="footer-col">
                <a href="/" class="logo mb-6 inline-block">
                    <img src="/public/public/logo-icon.png" alt="ZiGo Icon" class="icon" style="height: 60px;">
                </a>
                <p style="opacity: 0.6; line-height: 1.8;">Premium technology for the next generation of creators and
                    innovators.</p>
            </div>
            <div class="footer-col">
                <h4>Quick Links</h4>
                <ul class="footer-links">
                    <li><a href="/">Home</a></li>
                    <li><a href="/shop">Shop</a></li>
                    <li><a href="/categories">Categories</a></li>
                    <li><a href="/about">About</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Support</h4>
                <ul class="footer-links">
                    <li><a href="/contact">Help Center</a></li>
                    <li><a href="#">Privacy Policy</a></li>
                    <li><a href="#">Terms of Service</a></li>
                </ul>
            </div>
        </div>
        <div
            style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.1); text-align: center; opacity: 0.4; font-size: 0.8rem;">
            &copy; 2026 ZiGo Technologies. All rights reserved.
        </div>
    </footer>

    <script>
        window.onload = () => {
            document.getElementById('forgotCard').classList.add('active');
        }
    </script>
</body>

</html>
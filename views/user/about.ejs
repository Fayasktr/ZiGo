<main style="padding-top: 140px;">
    <!-- About Hero -->
    <section class="hero flex flex-col items-center text-center gap-6 py-32"
        style="background: linear-gradient(to bottom, #F0F0F0, var(--white));">
        <span class="text-[#FF5A1F] font-bold tracking-widest uppercase text-sm">Our Story</span>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold max-w-4xl text-[#0F0F0F]">Building the Future of
            <span class="bg-clip-text text-transparent bg-gradient-to-r from-[#0F0F0F] to-[#FF5A1F]">Electronic
                Commerce.</span>
        </h1>
        <p class="max-w-2xl text-[#0F0F0F]/70 text-lg">From a small tech collective to a global platform, ZiGo is
            redefining
            how you experience technology.</p>
    </section>

    <!-- Main About Content -->
    <section id="about" class="reveal py-24 bg-[#F9F9F9] text-[#0F0F0F]">
        <div class="max-w-6xl mx-auto px-5 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="about-visual relative">
                <div
                    class="w-full aspect-square bg-orange-500/5 rounded-3xl overflow-hidden border border-orange-500/10 relative group shadow-2xl">
                    <img src="/public/landing/hero_premium.png" alt="ZiGo Tech Innovation"
                        class="w-full h-full object-cover transition-all duration-700">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
                    <div class="absolute bottom-8 left-8">
                        <span class="text-white font-bold text-sm tracking-widest uppercase opacity-90">Innovation
                            Hub</span>
                        <h3 class="text-2xl font-bold text-white mt-1">Redefining Tech Since 2024</h3>
                    </div>
                </div>
                <div
                    class="absolute -top-6 -right-6 w-32 h-32 bg-[#FF5A1F] rounded-2xl flex items-center justify-center p-6 shadow-2xl rotate-12 hidden md:flex">
                    <p class="text-white font-bold text-center text-sm leading-tight">Top Rated Platform</p>
                </div>
            </div>
            <div class="about-content">
                <h2 class="text-3xl font-bold mb-6">Who We Are</h2>
                <p class="text-lg text-[#0F0F0F]/80 mb-8 leading-relaxed">
                    ZiGo isn't just another electronics store. We're a technology collective dedicated to bringing
                    premium, high-performance gadgets to everyone. Our mission is to bridge the gap between cutting-edge
                    innovation and accessible pricing.
                </p>
                <div class="grid grid-cols-2 gap-8 mb-10">
                    <div>
                        <h4 class="text-4xl font-bold text-[#FF5A1F]">50k+</h4>
                        <p class="text-sm text-[#0F0F0F]/60">Global App Downloads</p>
                    </div>
                    <div>
                        <h4 class="text-4xl font-bold text-[#FF5A1F]">99%</h4>
                        <p class="text-sm text-[#0F0F0F]/60">Customer Satisfaction</p>
                    </div>
                </div>
                <p class="text-[#0F0F0F]/80 leading-relaxed mb-8">
                    We believe technology should empower people. That's why we meticulously source every product in our
                    catalog, ensuring it meets our rigorous standards for quality, design, and usability.
                </p>
            </div>
        </div>
    </section>

    <!-- Mission & Values -->
    <section class="py-24 bg-white border-y border-black/5">
        <div class="max-w-6xl mx-auto px-5 text-[#0F0F0F]">
            <div class="section-header text-center mb-16">
                <h2 class="text-4xl font-bold mb-4">Our Values</h2>
                <p class="text-[#0F0F0F]/60 text-lg">The principles that drive us forward every day.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
                <div
                    class="value-card p-10 rounded-3xl bg-gray-50 border border-black/5 hover:border-[#FF5A1F]/30 hover:shadow-xl transition-all">
                    <div class="text-4xl mb-6">⚡</div>
                    <h3 class="text-xl font-bold mb-4">Speed</h3>
                    <p class="text-[#0F0F0F]/60">We move fast because technology doesn't wait. From order processing to
                        delivery, we optimize for speed.</p>
                </div>
                <div
                    class="value-card p-10 rounded-3xl bg-gray-50 border border-black/5 hover:border-[#FF5A1F]/30 hover:shadow-xl transition-all">
                    <div class="text-4xl mb-6">💎</div>
                    <h3 class="text-xl font-bold mb-4">Quality</h3>
                    <p class="text-[#0F0F0F]/60">We don't compromise. Every product undergoes a multi-point inspection
                        before
                        it reaches your door.</p>
                </div>
                <div
                    class="value-card p-10 rounded-3xl bg-gray-50 border border-black/5 hover:border-[#FF5A1F]/30 hover:shadow-xl transition-all">
                    <div class="text-4xl mb-6">🤝</div>
                    <h3 class="text-xl font-bold mb-4">Trust</h3>
                    <p class="text-[#0F0F0F]/60">Transparency is our core. We offer clear pricing, honest descriptions,
                        and
                        dedicated support.</p>
                </div>
            </div>
        </div>
    </section>
</main>

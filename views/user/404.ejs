<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 - Page Not Found | ZiGo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="icon" type="image/png" href="/public/public/favicon.png">
    <style>
        :root {
            --primary-orange: #FF5A1F;
            --primary-orange-hover: #E44D18;
            --deep-black: #0F0F0F;
            --off-white: #F9F9F9;
            --dark-navy: #1E293B;
            --gray-light: #E2E8F0;
            --white: #FFFFFF;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--deep-black);
            color: var(--white);
            overflow-x: hidden;
            line-height: 1.6;
        }



        /* --- 404 Section --- */
        .error-section {
            margin-top: 70px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 0 5%;
            background:
                radial-gradient(circle at center, rgba(255, 90, 31, 0.1) 0%, transparent 70%),
                var(--deep-black);
        }

        .error-code {
            font-size: 7rem;
            font-weight: 500;
            line-height: 1;
            color: transparent;
            -webkit-text-stroke: 2px rgba(255, 255, 255, 0.1);
            background: linear-gradient(45deg, var(--primary-orange), #fff);
            -webkit-background-clip: text;
            background-clip: text;
            position: relative;
            margin-bottom: 2rem;
        }


        .error-message h1 {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 1rem;
        }

        .error-message p {
            font-size: 1.2rem;
            opacity: 0.6;
            max-width: 500px;
            margin: 0 auto 3rem;
        }

        .btn {
            padding: 1rem 2.5rem;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 700;
            font-size: 1rem;
            transition: var(--transition);
            display: inline-block;
        }

        .btn-primary {
            background-color: var(--primary-orange);
            color: white;
            border: 2px solid var(--primary-orange);
        }

        .btn-primary:hover {
            background-color: var(--primary-orange-hover);
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(255, 90, 31, 0.3);
        }

        /* --- Footer --- */
        footer {
            background-color: #080808;
            padding: 5rem 5% 2rem;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 1.5fr 1fr 1fr 1fr;
            gap: 4rem;
            margin-bottom: 4rem;
        }

        .footer-col h4 {
            color: white;
            font-size: 1.1rem;
            font-weight: 700;
            margin-bottom: 2rem;
        }

        .footer-links {
            list-style: none;
        }

        .footer-links li {
            margin-bottom: 1rem;
        }

        .footer-links a {
            color: rgba(255, 255, 255, 0.6);
            text-decoration: none;
            transition: var(--transition);
            font-size: 0.95rem;
        }

        .footer-links a:hover {
            color: var(--primary-orange);
        }

        .footer-bottom {
            padding-top: 2rem;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            text-align: center;
            color: rgba(255, 255, 255, 0.4);
            font-size: 0.9rem;
        }
    </style>
</head>

<body>
    <%- include('../partials/headerBeforeLogin') %>

        <main class="error-section">
            <div class="error-code">404</div>
            <div class="error-message">
                <p>The page you're searching for seems to have vanished into the digital void. Let's get you back on
                    track.
                </p>
                <a href="/" class="btn btn-primary">Back to Home</a>
            </div>
        </main>

        <footer>
            <div class="footer-grid max-w-7xl mx-auto">
                <div class="footer-col">
                    <a href="/" class="logo mb-8 block">
                        <img src="/public/public/logo-icon.png" alt="ZiGo Icon" class="icon" style="height: 60px;">
                        <img src="/public/public/logo-name.png" alt="ZiGo" class="name" style="height: 30px;">
                    </a>
                    <p class="text-white/60 text-sm">Premium electronics, lightning-fast delivery, and prices that make
                        sense.</p>
                </div>
                <div class="footer-col">
                    <h4>Shop</h4>
                    <ul class="footer-links">
                        <li><a href="/shop?category=smartphones">Smartphones</a></li>
                        <li><a href="/shop?category=watches">Watches</a></li>
                        <li><a href="/shop?category=audio">Audio</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Support</h4>
                    <ul class="footer-links">
                        <li><a href="/about">About Us</a></li>
                        <li><a href="/contact">Contact Us</a></li>
                        <li><a href="#">FAQs</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Legal</h4>
                    <ul class="footer-links">
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="#">Terms of Service</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 ZiGo. All rights reserved.</p>
            </div>
        </footer>

        <script>

        </script>
</body>

</html>
<style>
    .reset-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: var(--deep-black);
        padding: 2rem;
        position: relative;
        overflow: hidden;
    }

    .reset-container::before {
        content: '';
        position: absolute;
        width: 1000px;
        height: 1000px;
        background: radial-gradient(circle, rgba(255, 90, 31, 0.1) 0%, transparent 70%);
        bottom: -500px;
        left: -500px;
        z-index: 1;
    }

    .reset-card {
        width: 100%;
        max-width: 1100px;
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 32px;
        display: flex;
        overflow: hidden;
        z-index: 2;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .reset-visual {
        flex: 1;
        background: url('/public/login/login-bg.png') center/cover no-repeat;
        display: none;
        position: relative;
    }

    .reset-visual::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to right, rgba(15, 15, 15, 0.8), transparent);
    }

    @media (min-width: 1024px) {
        .reset-visual {
            display: block;
        }
    }

    .reset-form-side {
        flex: 1;
        padding: 4rem 3.5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        color: var(--white);
    }

    .reset-header {
        margin-bottom: 2.5rem;
    }

    .reset-header h2 {
        font-size: 2.5rem;
        font-weight: 800;
        margin-bottom: 0.8rem;
        background: linear-gradient(to right, #fff, var(--primary-orange));
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .reset-header p {
        opacity: 0.6;
        font-size: 1rem;
        line-height: 1.6;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-group label {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        opacity: 0.8;
    }

    .input-wrapper input {
        width: 100%;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 1rem 1.2rem;
        border-radius: 12px;
        color: white;
        font-size: 1rem;
        outline: none;
        transition: var(--transition);
    }

    .input-wrapper input:focus {
        border-color: var(--primary-orange);
        background: rgba(255, 255, 255, 0.08);
        box-shadow: 0 0 0 4px rgba(255, 90, 31, 0.1);
    }

    .reset-btn {
        width: 100%;
        background: var(--primary-orange);
        color: white;
        border: none;
        padding: 1.1rem;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: var(--transition);
        margin-top: 1rem;
    }

    .reset-btn:hover {
        background: var(--primary-orange-hover);
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(255, 90, 31, 0.3);
    }
</style>

<div class="reset-container">
    <div class="reset-card reveal">
        <div class="reset-visual">
            <div class="absolute bottom-12 left-12 z-10">
                <h3 class="text-3xl font-extrabold text-white mb-2">Security First.</h3>
                <p class="text-white/60">Choose a strong password to protect your account.</p>
            </div>
        </div>

        <div class="reset-form-side">
            <div class="reset-header">
                <h2>Set New Password</h2>
                <p>Create a strong password that you haven't used before. Minimum 8 characters required.</p>
            </div>

            <form action="/resetPassword" method="POST">
                <div class="form-group">
                    <label for="password">New Password</label>
                    <div class="input-wrapper">
                        <input type="password" id="password" name="password" placeholder="••••••••" required>
                    </div>
                </div>

                <div class="form-group">
                    <label for="confirmPassword">Confirm New Password</label>
                    <div class="input-wrapper">
                        <input type="password" id="confirmPassword" name="confirmPassword" placeholder="••••••••"
                            required>
                    </div>
                </div>

                <button type="submit" class="reset-btn">Update Password & Login</button>
            </form>
        </div>
    </div>
</div>

<script>
    // Add active class to trigger the reveal animation
    window.addEventListener('load', () => {
        document.querySelector('.reset-card').classList.add('active');
    });
</script>

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZiGo | <%= (typeof address !=='undefined' ) ? 'Edit Address' : 'Add New Address' %>
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="icon" type="image/png" href="/public/public/favicon.png">
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- Custom Address JS -->
    <script src="/public/frendend.js/addressEdit.js"></script>
    <style>
        :root {
            --primary-orange: #FF5A1F;
            --primary-orange-hover: #E44D18;
            --deep-black: #0F0F0F;
            --off-white: #F9F9F9;
            --dark-navy: #1E293B;
            --gray-light: #E2E8F0;
            --white: #FFFFFF;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--off-white);
            color: var(--dark-navy);
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* --- Page Layout --- */
        .page-container {
            padding: 140px 5% 80px;
            max-width: 1000px;
            margin: 0 auto;
        }

        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--dark-navy);
            text-decoration: none;
            font-weight: 700;
            font-size: 0.9rem;
            margin-bottom: 2rem;
            opacity: 0.6;
            transition: var(--transition);
        }

        .back-btn:hover {
            opacity: 1;
            color: var(--primary-orange);
        }

        .form-card {
            background: white;
            border-radius: 32px;
            padding: 3rem;
            border: 1px solid var(--gray-light);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.02);
        }

        .form-header {
            margin-bottom: 3rem;
        }

        .form-title {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--dark-navy);
            margin-bottom: 0.5rem;
        }

        .form-subtitle {
            opacity: 0.5;
            font-weight: 500;
        }

        /* --- Form Elements --- */
        .form-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5rem;
        }

        @media (max-width: 768px) {
            .form-grid {
                grid-template-columns: 1fr;
            }
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group.full-width {
            grid-column: 1 / -1;
        }

        .form-label {
            display: block;
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            opacity: 0.4;
            margin-bottom: 0.5rem;
        }

        .form-input {
            width: 100%;
            padding: 1rem 1.5rem;
            border-radius: 16px;
            border: 2px solid var(--gray-light);
            font-weight: 600;
            outline: none;
            transition: var(--transition);
            background: var(--off-white);
        }

        .form-input:focus {
            border-color: var(--primary-orange);
            background: white;
            box-shadow: 0 0 0 4px rgba(255, 90, 31, 0.1);
        }

        .save-btn {
            width: 100%;
            background: var(--deep-black);
            color: white;
            padding: 1.2rem;
            border-radius: 20px;
            font-weight: 800;
            font-size: 1.1rem;
            transition: var(--transition);
            border: none;
            cursor: pointer;
            margin-top: 2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }

        .save-btn:hover {
            background: var(--primary-orange);
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(255, 90, 31, 0.2);
        }

        .error-msg {
            color: #ef4444;
            font-size: 0.7rem;
            font-weight: 600;
            margin-top: 4px;
            display: none;
        }

        .form-input.error {
            border-color: #ef4444;
        }
    </style>
</head>

<body>
    <%- include('../../partials/header') %>

        <main class="page-container">
            <a href="/user/addresses" class="back-btn">
                <i class="fas fa-arrow-left"></i> Back to Addresses
            </a>
            <!-- hiddern area to set address id  -->
            <% if (typeof address !=='undefined' ) { %>
                <input type="hidden" name="addressId" value="<%= address._id %>">
                <% } %>
                    <div class="form-card">
                        <div class="form-header">
                            <h1 class="form-title">
                                <%= (typeof address !=='undefined' ) ? 'Edit' : 'Add New' %> <span
                                        class="text-orange-500">Address</span>
                            </h1>
                            <p class="form-subtitle">Please provide your delivery details below.</p>
                        </div>

                        <form id="addressForm"
                            action="<%= (typeof address !== 'undefined') ? '/user/addresses/' + address._id + '/edit' : '/user/addresses/add' %>"
                            method="POST">

                            <% if (typeof address !=='undefined' ) { %>
                                <input type="hidden" name="id" value="<%= address._id %>">
                                <% } %>

                                    <div class="form-grid">
                                        <div class="form-group full-width">
                                            <label class="form-label">Full Name</label>
                                            <input type="text" name="userName" id="userName" class="form-input"
                                                placeholder=""
                                                value="<%= (typeof address !== 'undefined') ? address.userName : '' %>">
                                            <span class="error-msg" id="error-userName">Name must be at least 3
                                                characters and only contain letters.</span>
                                        </div>
                                        <div class="form-group full-width">
                                            <label class="form-label">Address Type</label>
                                            <select name="type" id="type" class="form-input">
                                                <option value="" disabled <%=(typeof address==='undefined' ||
                                                    !address.addressType) ? 'selected' : '' %>>
                                                    Select Type
                                                </option>

                                                <option value="Home" <%=(typeof address !=='undefined' &&
                                                    address.addressType==='Home' ) ? 'selected' : '' %>>
                                                    Home
                                                </option>
                                                <option value="Office" <%=(typeof address !=='undefined' &&
                                                    address.addressType==='Office' ) ? 'selected' : '' %>>
                                                    Office
                                                </option>

                                                <option value="Other" <%=(typeof address !=='undefined' &&
                                                    address.addressType==='Other' ) ? 'selected' : '' %>>
                                                    Other
                                                </option>
                                            </select>
                                            <span class="error-msg" id="error-type">Please select an address
                                                type.</span>
                                        </div>
                                        <div class="form-group full-width">
                                            <label class="form-label">Detailed Address</label>
                                            <textarea name="detailedAddress" id="detailedAddress" class="form-input"
                                                rows="3" placeholder="Street, Apartment, Locality..."
                                                style="resize:none;"><%= (typeof address !== 'undefined') ? address.detailedAddress : '' %></textarea>
                                            <span class="error-msg" id="error-detailedAddress">Address must be at least
                                                10 characters long.</span>
                                        </div>
                                        <div class="form-group">
                                            <label class="form-label">Country</label>
                                            <input type="text" name="country" id="country" class="form-input"
                                                value="<%= (typeof address !== 'undefined') ? address.country : 'India' %>">
                                            <span class="error-msg" id="error-country">Country must contain only
                                                letters.</span>
                                        </div>
                                        <div class="form-group">
                                            <label class="form-label">City</label>
                                            <input type="text" name="city" id="city" class="form-input" placeholder=""
                                                value="<%= (typeof address !== 'undefined') ? address.city : '' %>">
                                            <span class="error-msg" id="error-city">City must contain only
                                                letters.</span>
                                        </div>

                                        <div class="form-group">
                                            <label class="form-label">Pin Code</label>
                                            <input type="text" name="pincode" id="pincode" class="form-input"
                                                placeholder=""
                                                value="<%= (typeof address !== 'undefined') ? address.pincode : '' %>">
                                            <span class="error-msg" id="error-pincode">Please enter a valid numeric pin
                                                code.</span>
                                        </div>
                                        <div class="form-group">
                                            <label class="form-label">Phone Number</label>
                                            <input type="tel" name="phoneNumber" id="phoneNumber" class="form-input"
                                                placeholder="+91 "
                                                value="<%= (typeof address !== 'undefined') ? address.phoneNumber : '' %>">
                                            <span class="error-msg" id="error-phoneNumber">Please enter a valid numeric
                                                phone number.</span>
                                        </div>

                                        <div class="form-group full-width flex items-center gap-3 mt-4">
                                            <input type="checkbox" name="isDefault" id="isDefault"
                                                class="w-5 h-5 accent-orange-500 cursor-pointer" <%=(typeof address
                                                !=='undefined' && address.isDefault) ? 'checked' : '' %>>
                                            <label for="isDefault"
                                                class="text-sm font-bold opacity-60 cursor-pointer uppercase tracking-wider">Set
                                                as default address</label>
                                        </div>
                                    </div>


                                    <button type="button" onclick="submitAddressFormForEditAddress()" class="save-btn">
                                        <i class="fas fa-save"></i>
                                        <%= (typeof address !=='undefined' ) ? 'Update Address' : 'Save Address' %>
                                    </button>
                        </form>
                    </div>
        </main>

        <%- include('../../partials/footer') %>

            <script>

            </script>
</body>

</html>
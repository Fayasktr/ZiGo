<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZiGo | <%= (typeof address !=='undefined' ) ? 'Edit Address' : 'Add New Address' %>
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="icon" type="image/png" href="/public/public/favicon.png">
    <style>
        :root {
            --primary-orange: #FF5A1F;
            --primary-orange-hover: #E44D18;
            --deep-black: #0F0F0F;
            --off-white: #F9F9F9;
            --dark-navy: #1E293B;
            --gray-light: #E2E8F0;
            --white: #FFFFFF;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--off-white);
            color: var(--dark-navy);
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* --- Page Layout --- */
        .page-container {
            padding: 140px 5% 80px;
            max-width: 1000px;
            margin: 0 auto;
        }

        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--dark-navy);
            text-decoration: none;
            font-weight: 700;
            font-size: 0.9rem;
            margin-bottom: 2rem;
            opacity: 0.6;
            transition: var(--transition);
        }

        .back-btn:hover {
            opacity: 1;
            color: var(--primary-orange);
        }

        .form-card {
            background: white;
            border-radius: 32px;
            padding: 3rem;
            border: 1px solid var(--gray-light);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.02);
        }

        .form-header {
            margin-bottom: 3rem;
        }

        .form-title {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--dark-navy);
            margin-bottom: 0.5rem;
        }

        .form-subtitle {
            opacity: 0.5;
            font-weight: 500;
        }

        /* --- Form Elements --- */
        .form-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5rem;
        }

        @media (max-width: 768px) {
            .form-grid {
                grid-template-columns: 1fr;
            }
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group.full-width {
            grid-column: 1 / -1;
        }

        .form-label {
            display: block;
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            opacity: 0.4;
            margin-bottom: 0.5rem;
        }

        .form-input {
            width: 100%;
            padding: 1rem 1.5rem;
            border-radius: 16px;
            border: 2px solid var(--gray-light);
            font-weight: 600;
            outline: none;
            transition: var(--transition);
            background: var(--off-white);
        }

        .form-input:focus {
            border-color: var(--primary-orange);
            background: white;
            box-shadow: 0 0 0 4px rgba(255, 90, 31, 0.1);
        }

        .save-btn {
            width: 100%;
            background: var(--deep-black);
            color: white;
            padding: 1.2rem;
            border-radius: 20px;
            font-weight: 800;
            font-size: 1.1rem;
            transition: var(--transition);
            border: none;
            cursor: pointer;
            margin-top: 2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }

        .save-btn:hover {
            background: var(--primary-orange);
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(255, 90, 31, 0.2);
        }
    </style>
</head>

<body>
    <%- include('../../partials/header') %>

        <main class="page-container">
            <a href="/user/addresses" class="back-btn">
                <i class="fas fa-arrow-left"></i> Back to Addresses
            </a>
            <!-- hiddern area to set address id  -->
            <% if (typeof address !=='undefined' ) { %>
                <input type="hidden" name="addressId" value="<%= address._id %>">
                <% } %>
                    <div class="form-card">
                        <div class="form-header">
                            <h1 class="form-title">
                                <%= (typeof address !=='undefined' ) ? 'Edit' : 'Add New' %> <span
                                        class="text-orange-500">Address</span>
                            </h1>
                            <p class="form-subtitle">Please provide your delivery details below.</p>
                        </div>

                        <form id="addressForm"
                            action="<%= (typeof address !== 'undefined') ? '/user/addresses/Edit/' + address._id : '/user/addresses/Edit' %>"
                            method="POST">

                            <% if (typeof address !=='undefined' ) { %>
                                <input type="hidden" name="addressId" value="<%= address._id %>">
                                <% } %>

                                    <div class="form-grid">
                                        <div class="form-group full-width">
                                            <label class="form-label">Full Name</label>
                                            <input type="text" name="fullName" class="form-input" placeholder=""
                                                value="<%= (typeof address !== 'undefined') ? address.fullName : '' %>"
                                                required>
                                        </div>
                                        <div class="form-group full-width">
                                            <label class="form-label">Address Type</label>
                                            <input type="text" name="type" class="form-input"
                                                placeholder="e.g. Home, Office, Studio"
                                                value="<%= (typeof address !== 'undefined') ? address.type : '' %>"
                                                required>
                                        </div>
                                        <div class="form-group full-width">
                                            <label class="form-label">Detailed Address</label>
                                            <textarea name="street" class="form-input" rows="3"
                                                placeholder="Street, Apartment, Locality..." style="resize:none;"
                                                required><%= (typeof address !== 'undefined') ? address.street : '' %></textarea>
                                        </div>
                                        <div class="form-group">
                                            <label class="form-label">Country</label>
                                            <input type="text" name="country" class="form-input"
                                                value="<%= (typeof address !== 'undefined') ? address.country : 'India' %>"
                                                required>
                                        </div>
                                        <div class="form-group">
                                            <label class="form-label">City</label>
                                            <input type="text" name="city" class="form-input" placeholder=""
                                                value="<%= (typeof address !== 'undefined') ? address.city : '' %>"
                                                required>
                                        </div>
                                        <div class="form-group">
                                            <label class="form-label">State</label>
                                            <input type="text" name="state" class="form-input" placeholder=""
                                                value="<%= (typeof address !== 'undefined') ? address.state : '' %>"
                                                required>
                                        </div>
                                        <div class="form-group">
                                            <label class="form-label">Pin Code</label>
                                            <input type="text" name="pincode" class="form-input" placeholder=""
                                                value="<%= (typeof address !== 'undefined') ? address.pincode : '' %>"
                                                required>
                                        </div>
                                        <div class="form-group">
                                            <label class="form-label">Phone Number</label>
                                            <input type="tel" name="phone" class="form-input" placeholder="+91 "
                                                value="<%= (typeof address !== 'undefined') ? address.phone : '' %>"
                                                required>
                                        </div>
                                        <div class="form-group">
                                            <label class="form-label">Email Address </label>
                                            <input type="email" name="email" class="form-input" placeholder=""
                                                value="<%= (typeof address !== 'undefined') ? address.email : '' %>">
                                        </div>
                                    </div>

                                    <div class="flex items-center gap-3 mt-4 mb-8">
                                        <input type="checkbox" name="isDefault" id="setAsDefault"
                                            class="w-5 h-5 accent-orange-500" <%=(typeof address !=='undefined' &&
                                            address.isDefault) ? 'checked' : '' %>>
                                        <label for="setAsDefault" class="text-sm font-bold opacity-60">Set as default
                                            delivery
                                            address</label>
                                    </div>

                                    <button type="submit" class="save-btn">
                                        <i class="fas fa-save"></i>
                                        <%= (typeof address !=='undefined' ) ? 'Update Address' : 'Save Address' %>
                                    </button>
                        </form>
                    </div>
        </main>

        <%- include('../../partials/footer') %>

            <script>

            </script>
</body>

</html>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZiGo | My Wishlist</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="icon" type="image/png" href="/public/public/favicon.png">
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        :root {
            --primary-orange: #FF5A1F;
            --primary-orange-hover: #E44D18;
            --deep-black: #0F0F0F;
            --off-white: #F9F9F9;
            --dark-navy: #1E293B;
            --gray-light: #E2E8F0;
            --white: #FFFFFF;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--off-white);
            color: var(--dark-navy);
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* --- Profile Container --- */
        .profile-container {
            padding: 140px 5% 80px;
            max-width: 1400px;
            margin: 0 auto;
        }

        .profile-layout {
            display: grid;
            grid-template-columns: 320px 1fr;
            gap: 3rem;
        }

        @media (max-width: 1024px) {
            .profile-layout {
                grid-template-columns: 1fr;
            }
        }

        /* --- Sidebar --- */
        .profile-sidebar {
            background: white;
            border-radius: 32px;
            padding: 2.5rem;
            border: 1px solid var(--gray-light);
            height: min-content;
            position: sticky;
            top: 120px;
        }

        .user-info {
            text-align: center;
            margin-bottom: 2.5rem;
            padding-bottom: 2rem;
            border-bottom: 1px solid var(--gray-light);
        }

        .user-avatar-large {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            border: 4px solid var(--primary-orange);
            margin: 0 auto 1.5rem;
            overflow: hidden;
            box-shadow: 0 10px 20px rgba(255, 90, 31, 0.15);
        }

        .user-avatar-large img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .user-name {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--dark-navy);
        }

        .user-email {
            font-size: 0.9rem;
            opacity: 0.5;
        }

        .sidebar-nav {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 1.2rem;
            padding: 1.1rem 1.5rem;
            border-radius: 16px;
            text-decoration: none;
            color: var(--dark-navy);
            font-weight: 600;
            transition: var(--transition);
            cursor: pointer;
        }

        .sidebar-link i {
            font-size: 1.2rem;
            width: 24px;
            text-align: center;
            opacity: 0.4;
            transition: var(--transition);
        }

        .sidebar-link:hover {
            background: var(--off-white);
            color: var(--primary-orange);
        }

        .sidebar-link:hover i {
            opacity: 1;
            color: var(--primary-orange);
        }

        .sidebar-link.active {
            background: var(--primary-orange);
            color: white;
            box-shadow: 0 10px 20px rgba(255, 90, 31, 0.2);
        }

        .sidebar-link.active i {
            opacity: 1;
            color: white;
        }

        .logout-link {
            margin-top: 1rem;
            color: #ff4757;
        }

        .logout-link:hover {
            background: rgba(255, 71, 87, 0.1);
            color: #ff4757;
        }

        /* --- Content Panels --- */
        .panel-header {
            margin-bottom: 2.5rem;
        }

        .panel-title {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--dark-navy);
        }

        .wishlist-card {
            transition: var(--transition);
        }

        .wishlist-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
        }
    </style>
</head>

<body>
    <%- include('../../partials/header') %>

        <main class="profile-container">
            <div class="profile-layout">
                <!-- Sidebar -->
                <aside class="profile-sidebar">
                    <div class="user-info">
                        <div class="user-avatar-large">
                            <% if (user && user.profileImage) { %>
                                <img src="<%= user.profileImage %>" alt="User">
                                <% } else { %>
                                    <img src="https://ui-avatars.com/api/?name=<%= user.userName %>&background=FF5A1F&color=fff"
                                        alt="User">
                                    <% } %>
                        </div>
                        <h2 class="user-name">
                            <%= user.userName %>
                        </h2>
                        <p class="user-email text-gray-500">
                            <%= user.email %>
                        </p>
                    </div>

                    <nav class="sidebar-nav">
                        <a href="/user/profile" class="sidebar-link">
                            <i class="fas fa-th-large"></i> Overview
                        </a>
                        <a href="/user/orders" class="sidebar-link">
                            <i class="fas fa-shopping-bag"></i> Order History
                        </a>
                        <a href="/user/wallet" class="sidebar-link">
                            <i class="fas fa-wallet"></i> My Wallet
                        </a>
                        <a href="/user/wishlist" class="sidebar-link active">
                            <i class="fas fa-heart"></i> Wishlist
                        </a>
                        <a href="/user/addresses" class="sidebar-link">
                            <i class="fas fa-map-marker-alt"></i> Addresses
                        </a>
                        <a href="/user/cart" class="sidebar-link">
                            <i class="fas fa-shopping-cart"></i> My Cart
                        </a>
                        <a href="/logout" class="sidebar-link logout-link">
                            <i class="fas fa-sign-out-alt"></i> Logout
                        </a>
                    </nav>
                </aside>

                <!-- Main Content Area -->
                <div class="profile-content">
                    <!-- Wishlist Panel -->
                    <div id="wishlist-panel">
                        <div class="panel-header">
                            <h1 class="panel-title">My <span class="text-orange-500">Wishlist</span></h1>
                        </div>

                        <% if (wishlist && wishlist.length> 0) { %>
                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                                <% wishlist.forEach(item=> { %>
                                    <% if (item.productId) { %>
                                        <div
                                            class="wishlist-card bg-white p-6 rounded-[32px] border border-gray-100 flex flex-col items-center relative group">
                                            <!-- Remove Button -->
                                            <button
                                                onclick="removeFromWishlist('<%= item.productId._id %>', '<%= item.variantId %>')"
                                                class="absolute top-4 right-4 w-8 h-8 rounded-full bg-gray-50 flex items-center justify-center text-gray-400 hover:text-red-500 transition-colors">
                                                <i class="fas fa-times"></i>
                                            </button>

                                            <div class="w-40 h-40 flex items-center justify-center mb-4 cursor-pointer"
                                                onclick="window.location.href='/productDetailse/<%= item.productId._id %>'">
                                                <% const wishlistVariant=(item.productId && item.productId.variants &&
                                                    item.variantId) ? item.productId.variants.find(v=> v._id &&
                                                    item.variantId && v._id.toString() === item.variantId.toString()) :
                                                    (item.productId && item.productId.variants ?
                                                    item.productId.variants[0] : null);

                                                    const wishlistImg = (wishlistVariant && wishlistVariant.images &&
                                                    wishlistVariant.images[0]) ?
                                                    wishlistVariant.images[0] :
                                                    '/public/landing/no-image.png';
                                                    %>
                                                    <img src="<%= wishlistImg %>"
                                                        alt="<%= item.productId.productName %>"
                                                        class="max-w-full max-h-full object-contain">
                                            </div>

                                            <h4 class="font-bold text-center mb-1 text-lg">
                                                <%= item.productId.productName %>
                                            </h4>
                                            <p class="text-gray-400 text-xs mb-3 uppercase tracking-wider font-bold">
                                                <%= item.productId.brand || 'Premium Tech' %>
                                            </p>

                                            <p class="text-orange-500 font-extrabold text-xl mb-6">
                                                ₹<%= wishlistVariant ? wishlistVariant.price.toLocaleString() : 'N/A' %>
                                            </p>

                                            <div class="flex flex-col gap-2 w-full">
                                                <button
                                                    onclick="moveToCart('<%= item.productId._id %>', '<%= item.variantId %>')"
                                                    class="w-full bg-black text-white py-4 rounded-2xl font-bold text-sm hover:bg-orange-600 transition-all duration-300">
                                                    Move to Cart
                                                </button>
                                            </div>
                                        </div>
                                        <% } %>
                                            <% }) %>
                            </div>
                            <% } else { %>
                                <div
                                    class="text-center py-20 bg-white rounded-[40px] border border-dashed border-gray-300">
                                    <div
                                        class="w-24 h-24 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6 text-gray-200">
                                        <i class="fas fa-heart text-4xl"></i>
                                    </div>
                                    <h3 class="text-2xl font-bold mb-2">Your wishlist is empty</h3>
                                    <p class="text-gray-500 mb-8">Save items you like in your wishlist to buy them
                                        later.</p>
                                    <a href="/shop"
                                        class="inline-block bg-orange-500 text-white px-8 py-3 rounded-xl font-bold hover:bg-orange-600 transition-colors">
                                        Start Shopping
                                    </a>
                                </div>
                                <% } %>
                    </div>
                </div>
            </div>
        </main>


        <script>
            async function removeFromWishlist(productId, variantId) {
                try {
                    const response = await fetch(`/shop/wishlist/${productId}?variantId=${variantId}`, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' }
                    });
                    const result = await response.json();

                    if (result.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Removed!',
                            text: result.message,
                            toast: true,
                            position: 'top',
                            showConfirmButton: false,
                            timer: 3000
                        });
                        // Reload to update the list
                        setTimeout(() => window.location.reload(), 1000);
                    }
                } catch (error) {
                    console.error(error);
                }
            }

            async function moveToCart(productId, variantId) {
                try {
                    // Assuming you'll have a moveToCart route or similar
                    const response = await fetch(`/shop/cart/${productId}?variantId=${variantId}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    });
                    const result = await response.json();

                    if (result.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Moved to Cart!',
                            text: result.message,
                            toast: true,
                            position: 'top',
                            showConfirmButton: false,
                            timer: 3000
                        });
                        // Reload to update list (remove from wishlist if moved)
                        setTimeout(() => window.location.reload(), 1500);
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Oops...',
                            text: result.message
                        });
                    }
                } catch (error) {
                    console.error(error);
                }
            }
        </script>
</body>

</html>
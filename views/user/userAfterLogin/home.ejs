<style>
    /* Specific Landing Page Styles Overriding main.hbs when needed */
    :root {
        --off-white: #F9F9F9;
        --dark-navy: #1E293B;
    }

    /* Ensuring the landing page feels light as per the HTML version */
    .landing-wrapper {
        background-color: var(--deep-black);
        color: var(--white);
    }

    /* --- Hero Section --- */
    .hero {
        min-height: 800px;
        background-color: var(--deep-black);
        background-image:
            radial-gradient(circle at 80% 20%, rgba(255, 90, 31, 0.15) 0%, transparent 40%),
            radial-gradient(circle at 20% 80%, rgba(255, 90, 31, 0.05) 0%, transparent 40%),
            linear-gradient(to bottom, transparent, rgba(15, 15, 15, 0.8));
        padding: 0;
        color: var(--white);
        position: relative;
        overflow: hidden;
    }

    .hero-content h1 {
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 1.5rem;
        letter-spacing: -2px;
    }

    .hero-content h1 span {
        color: var(--primary-orange);
        display: block;
        text-shadow: 0 0 30px rgba(255, 90, 31, 0.3);
    }

    .hero-visual {
        flex: 1;
        display: flex;
        justify-content: flex-end;
        z-index: 2;
    }

    .hero-visual img {
        max-width: 85%;
        height: auto;
        object-fit: cover;
        border-radius: 32px;
        box-shadow: 0 20px 100px rgba(255, 90, 31, 0.45), 0 0 40px rgba(255, 90, 31, 0.2);
        filter: brightness(1.05);
        animation: float 6s ease-in-out infinite;
    }

    @keyframes float {
        0% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-20px);
        }

        100% {
            transform: translateY(0px);
        }
    }

    /* --- Trust Strip --- */
    .trust-strip {
        padding: 4rem 0;
        background-color: var(--white);
        border-bottom: 1px solid var(--gray-light);
        color: var(--dark-navy);
    }

    .trust-item {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .trust-icon {
        width: 48px;
        height: 48px;
        background-color: rgba(255, 90, 31, 0.1);
        border-radius: 12px;
        display: flex;
        justify-content: center;
        align-items: center;
        color: var(--primary-orange);
        font-size: 1.5rem;
        transition: var(--transition);
    }

    /* --- Category Showcase --- */
    .categories {
        padding: 8rem 0;
        background-color: var(--off-white);
        color: var(--dark-navy);
    }

    .category-card {
        background-color: var(--white);
        border-radius: 20px;
        padding: 2rem;
        text-align: center;
        text-decoration: none;
        color: var(--dark-navy);
        transition: var(--transition);
        border: 1px solid var(--gray-light);
    }

    .category-card:hover {
        transform: translateY(-10px);
        border-color: var(--primary-orange);
    }

    /* --- Featured Products --- */
    .featured-products {
        padding: 0 0 8rem;
        background-color: var(--off-white);
        color: var(--dark-navy);
    }

    .product-card {
        background-color: var(--white);
        border-radius: 24px;
        overflow: hidden;
        border: 1px solid var(--gray-light);
        transition: var(--transition);
        position: relative;
    }

    .product-info h3 {
        color: var(--dark-navy);
    }

    .product-info p {
        color: var(--dark-navy);
    }

    /* --- Why ZiGo --- */
    .why-zigo {
        padding: 8rem 0;
        background-color: var(--deep-black);
        color: var(--white);
    }

    /* --- Brands Strip --- */
    .brands-strip {
        padding: 4rem 0;
        background-color: var(--white);
        border-bottom: 1px solid var(--gray-light);
    }

    .brand-logo {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--dark-navy);
        opacity: 0.5;
        transition: var(--transition);
    }

    .brand-logo:hover {
        opacity: 1;
        color: var(--primary-orange);
    }

    /* --- User Reviews --- */
    .reviews {
        padding: 8rem 0;
        background-color: var(--off-white);
        color: var(--dark-navy);
    }

    .review-card {
        background-color: var(--white);
        padding: 2.5rem;
        border-radius: 24px;
        border: 1px solid var(--gray-light);
        transition: var(--transition);
    }

    /* --- Newsletter --- */
    .newsletter {
        padding: 6rem 0;
        background-color: var(--primary-orange);
        color: var(--white);
        text-align: center;
    }

    .newsletter-form input {
        padding: 1rem 1.5rem;
        border-radius: 12px;
        border: none;
        outline: none;
        color: var(--dark-navy);
    }

    .newsletter-form button {
        padding: 1rem 2.5rem;
        border-radius: 12px;
        background-color: var(--deep-black);
        color: white;
        font-weight: 700;
        transition: var(--transition);
    }

    .newsletter-form button:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
    }
</style>


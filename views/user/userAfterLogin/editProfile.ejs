<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZiGo | Edit Profile</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="icon" type="image/png" href="/public/public/favicon.png">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/public/frendend.js/profileEdit.js" defer></script>
    <style>
        :root {
            --primary-orange: #FF5A1F;
            --primary-orange-hover: #E44D18;
            --deep-black: #0F0F0F;
            --off-white: #F9F9F9;
            --dark-navy: #1E293B;
            --gray-light: #E2E8F0;
            --white: #FFFFFF;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--off-white);
            color: var(--dark-navy);
            overflow-x: hidden;
            line-height: 1.6;
        }

        .edit-container {
            padding: 140px 5% 80px;
            max-width: 900px;
            margin: 0 auto;
        }

        .breadcrumb {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 2rem;
            font-size: 0.9rem;
            opacity: 0.5;
        }

        .breadcrumb a {
            text-decoration: none;
            color: inherit;
            transition: var(--transition);
        }

        .breadcrumb a:hover {
            color: var(--primary-orange);
            opacity: 1;
        }

        .edit-card {
            background: white;
            border-radius: 40px;
            padding: 3rem;
            border: 1px solid var(--gray-light);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.03);
            margin-bottom: 2.5rem;
        }

        .card-header {
            margin-bottom: 2.5rem;
            border-bottom: 1px solid var(--off-white);
            padding-bottom: 1.5rem;
        }

        .section-title {
            font-size: 1.75rem;
            font-weight: 800;
            color: var(--dark-navy);
        }

        .avatar-section {
            display: flex;
            flex-direction: column;
            align-items: center;
            margin-bottom: 3rem;
        }

        .avatar-preview-wrapper {
            position: relative;
            width: 120px;
            height: 120px;
            margin-bottom: 1rem;
        }

        .avatar-preview {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid var(--primary-orange);
            box-shadow: 0 10px 20px rgba(255, 90, 31, 0.15);
        }

        .upload-badge {
            position: absolute;
            bottom: 0;
            right: 0;
            background: var(--deep-black);
            color: white;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            border: 3px solid white;
            transition: var(--transition);
        }

        .upload-badge:hover {
            background: var(--primary-orange);
            transform: scale(1.1);
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }

        @media (max-width: 640px) {
            .form-grid {
                grid-template-columns: 1fr;
            }
        }

        .form-group {
            margin-bottom: 1.5rem;
            position: relative;
        }

        .form-label {
            display: block;
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 0.6rem;
            color: var(--dark-navy);
            opacity: 0.4;
        }

        .form-input {
            width: 100%;
            padding: 1.1rem 1.5rem;
            border-radius: 20px;
            border: 2px solid var(--gray-light);
            font-size: 1rem;
            font-weight: 600;
            outline: none;
            transition: var(--transition);
            background: var(--off-white);
        }

        .form-input:focus {
            background: white;
            border-color: var(--primary-orange);
            box-shadow: 0 0 0 5px rgba(255, 90, 31, 0.1);
        }

        .verified-badge {
            position: absolute;
            right: 20px;
            top: 42px;
            color: #2ED573;
            font-size: 0.8rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .save-btn {
            width: 100%;
            background: var(--deep-black);
            color: white;
            padding: 1.2rem;
            border-radius: 20px;
            font-weight: 800;
            font-size: 0.95rem;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
            border: none;
            gap: 10px;
            margin-top: 1rem;
        }

        .save-btn:hover {
            background: var(--primary-orange);
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(255, 90, 31, 0.2);
        }

        .cancel-btn {
            display: block;
            text-align: center;
            margin-top: 2rem;
            font-weight: 700;
            font-size: 0.9rem;
            color: var(--dark-navy);
            opacity: 0.5;
            text-decoration: none;
            transition: var(--transition);
        }

        .cancel-btn:hover {
            opacity: 1;
            color: var(--primary-orange);
        }

        .error-msg {
            color: #ef4444;
            font-size: 0.75rem;
            font-weight: 600;
            margin-top: 4px;
            display: none;
        }

        .form-input.error {
            border-color: #ef4444;
            background: #fef2f2;
        }

        /* --- Email Display & Modal --- */
        .email-display-container {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: var(--off-white);
            padding: 1rem 1.5rem;
            border-radius: 20px;
            border: 2px solid var(--gray-light);
        }

        .email-text-box {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .email-text {
            font-size: 1rem;
            font-weight: 700;
            color: var(--dark-navy);
        }

        .verified-badge-inline {
            font-size: 0.7rem;
            font-weight: 800;
            color: #2ed573;
            text-transform: uppercase;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .edit-email-btn {
            background: var(--deep-black);
            color: white;
            padding: 0.6rem 1.2rem;
            border-radius: 12px;
            font-size: 0.85rem;
            font-weight: 700;
            cursor: pointer;
            transition: var(--transition);
            border: none;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .edit-email-btn:hover {
            background: var(--primary-orange);
            transform: translateY(-2px);
        }

        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(8px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 2000;
            opacity: 0;
            visibility: hidden;
            transition: var(--transition);
        }

        .modal-overlay.active {
            opacity: 1;
            visibility: visible;
        }

        .modal-content {
            background: white;
            padding: 3rem;
            border-radius: 32px;
            width: 100%;
            max-width: 450px;
            position: relative;
            transform: scale(0.9);
            transition: var(--transition);
        }

        .modal-overlay.active .modal-content {
            transform: scale(1);
        }

        .modal-header {
            margin-bottom: 2rem;
            text-align: center;
        }

        .modal-header h3 {
            font-size: 1.5rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
        }

        .modal-subtitle {
            font-size: 0.9rem;
            color: #64748b;
            text-align: center;
            margin-bottom: 2rem;
        }

        .close-modal {
            position: absolute;
            top: 20px;
            right: 20px;
            background: none;
            border: none;
            font-size: 1.5rem;
            cursor: pointer;
            color: #94a3b8;
        }
    </style>
</head>

<body>
    <%- include('../../partials/header') %>

        <main class="edit-container">
            <nav class="breadcrumb">
                <a href="/ZiGo.com">Home</a>
                <i class="fas fa-chevron-right text-[10px]"></i>
                <a href="/user/profile">My Account</a>
                <i class="fas fa-chevron-right text-[10px]"></i>
                <span class="opacity-100 font-bold text-black">Edit Profile</span>
            </nav>

            <section class="edit-card">
                <div class="card-header">
                    <h1 class="section-title">Personal <span class="text-orange-500">Information</span></h1>
                </div>

                <div class="avatar-section">
                    <div class="avatar-preview-wrapper">
                        <img src="<%= (userData.profileImage) ? userData.profileImage : 'https://ui-avatars.com/api/?name=' + userData.userName + '&background=FF5A1F&color=fff' %>"
                            alt="Profile Preview" class="avatar-preview" id="profileImage">
                        <label for="imageUpload" class="upload-badge">
                            <i class="fas fa-camera"></i>
                            <input type="file" name="profileImage" id="imageUpload" class="hidden" accept="image/*"
                                onchange="previewAvatar(this)">
                        </label>
                    </div>
                    <p class="text-xs font-bold opacity-30">UPLOAD NEW PHOTO</p>
                    <button type="button" onclick="uploadProfileImage()"
                        class="mt-4 bg-orange-600 hover:bg-orange-700 text-white text-[10px] font-black tracking-widest py-2 px-6 rounded-xl transition-all shadow-lg hover:shadow-orange-500/20 active:scale-95 uppercase">
                        Save Profile Photo
                    </button>

                    <div class="mt-8 pt-8 border-t border-gray-100 w-full">
                        <form id="basicInfoForm" class="space-y-6">
                            <div class="form-grid">
                                <div class="form-group">
                                    <label class="form-label text-left">Username</label>
                                    <input type="text" id="userName" class="form-input" placeholder="e.g. fayas_kp"
                                        value="<%= userData.userName %>">
                                </div>
                                <div class="form-group">
                                    <label class="form-label text-left">Phone Number</label>
                                    <div class="relative">
                                        <span class="absolute left-6 top-[1.2rem] font-bold opacity-30">+91</span>
                                        <input type="tel" id="phoneNumber" class="form-input pl-16"
                                            placeholder="9876543210" value="<%= userData.phoneNumber || '' %>">
                                    </div>
                                </div>
                            </div>
                            <button type="button" onclick="updateBasicInfo()"
                                class="save-btn bg-deep-black hover:bg-orange-600 transition-all">
                                <i class="fas fa-user-edit"></i> Update Basic Profile
                            </button>
                        </form>
                    </div>
                </div>
            </section>

            <!-- Conditional Content based on Google Identity -->
            <% if(!userData.googleId) { %>
                <!-- Email Section (Local Only) -->
                <section class="edit-card">
                    <div class="card-header flex items-center justify-between">
                        <h1 class="section-title">Email <span class="text-orange-500">Address</span></h1>
                        <i class="fas fa-envelope-open-text text-gray-300 text-xl"></i>
                    </div>
                    <div class="email-display-container">
                        <div class="email-text-box">
                            <span class="email-text">
                                <%= userData.email %>
                            </span>
                            <span class="verified-badge-inline"><i class="fas fa-check-circle"></i> Verified
                                Account</span>
                        </div>
                        <button type="button" onclick="openEmailModal()" class="edit-email-btn">
                            <i class="fas fa-edit"></i> Change Email
                        </button>
                    </div>
                    
                </section>

                <!-- Security Section (Local Only) -->
                <section class="edit-card">
                    <div class="card-header flex items-center justify-between">
                        <h1 class="section-title">Security <span class="text-orange-500">Settings</span></h1>
                        <i class="fas fa-lock text-gray-300 text-xl"></i>
                    </div>
                    <form id="passwordForm">
                        <div class="form-group">
                            <label class="form-label">Current Password</label>
                            <input type="password" id="currentPassword" class="form-input" placeholder="••••••••">
                            <span class="error-msg" id="error-currentPassword">Current password is required.</span>
                        </div>
                        <div class="form-grid">
                            <div class="form-group">
                                <label class="form-label">New Password</label>
                                <input type="password" id="newPassword" class="form-input"
                                    placeholder="Min 6 characters">
                                <span class="error-msg" id="error-newPassword">Password must be at least 6
                                    characters.</span>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Confirm New Password</label>
                                <input type="password" id="confirmPassword" class="form-input"
                                    placeholder="Repeat new password">
                                <span class="error-msg" id="error-confirmPassword">Passwords do not match.</span>
                            </div>
                        </div>
                        <button type="button" onclick="updatePassword()"
                            class="save-btn bg-orange-600 hover:bg-orange-700">
                            <i class="fas fa-key"></i> Update Secure Password
                        </button>
                    </form>
                </section>
                <% } else { %>
                    <!-- Google User Info -->
                    <div class="edit-card border-blue-100 bg-blue-50/50">
                        <div class="flex items-start gap-4">
                            <div class="bg-blue-600 p-3 rounded-2xl text-white">
                                <i class="fab fa-google text-2xl"></i>
                            </div>
                            <div>
                                <h3 class="text-lg font-bold text-blue-900">Google Managed Account</h3>
                                <p class="text-sm text-blue-700 opacity-80 mt-1">Your security settings and email are
                                    directly managed by Google. You don't need to change passwords here.</p>
                            </div>
                        </div>
                    </div>
                    <% } %>

                        <a href="/user/profile" class="cancel-btn">
                            <i class="fas fa-arrow-left mr-2"></i> Back to My Account
                        </a>
        </main>

        <!-- Email Edit Modal -->
        <div id="emailModal" class="modal-overlay">
            <div class="modal-content">
                <button type="button" onclick="closeEmailModal()" class="close-modal">
                    <i class="fas fa-times"></i>
                </button>
                <div class="modal-header">
                    <h3>Update <span class="text-orange-500">Email</span></h3>
                </div>
                <p class="modal-subtitle">Enter your new email address. We'll send an OTP to verify it.</p>
                <form id="emailEditForm">
                    <div class="form-group">
                        <label class="form-label">New Email Address</label>
                        <input type="email" id="newEmailInput" class="form-input" placeholder="e.g. personal@fayas.com">
                        <span class="error-msg" id="error-newEmail">Please enter a valid email.</span>
                    </div>
                    <button type="button" onclick="submitEmailChange()" class="save-btn">
                        <i class="fas fa-paper-plane"></i> Send Verification OTP
                    </button>
                </form>
            </div>
        </div>

        <%- include('../../partials/footer') %>

            <div id="flash-data"
                data-error="<%= (typeof error !== 'undefined' && error && error.length > 0) ? error : '' %>"
                data-success="<%= (typeof success !== 'undefined' && success && success.length > 0) ? success : '' %>"
                style="display: none;">
            </div>

            <script>
                async function uploadProfileImage() {
                    const fileInput = document.getElementById('imageUpload');
                    if (!fileInput.files[0]) return;

                    const formData = new FormData();
                    formData.append('profileImage', fileInput.files[0]);

                    try {
                        Swal.fire({
                            title: 'Uploading...',
                            allowOutsideClick: false,
                            didOpen: () => Swal.showLoading()
                        });

                        const response = await fetch('/user/profile/image', {
                            method: 'PATCH',
                            body: formData
                        });

                        const result = await response.json();
                        if (response.ok) {
                            if (result.imageUrl) {
                                document.getElementById('profileImage').src = result.imageUrl;
                                const headerAvatar = document.getElementById('headerProfileImage');
                                if (headerAvatar) headerAvatar.src = result.imageUrl;
                            }

                            Swal.fire({
                                icon: 'success',
                                title: 'Success!',
                                text: result.message,
                                timer: 2000,
                                showConfirmButton: false
                            });
                        } else {
                            throw new Error(result.message);
                        }
                    } catch (error) {
                        Swal.fire('Error', error.message, 'error');
                    }
                }

                function previewAvatar(input) {
                    if (input.files && input.files[0]) {
                        const reader = new FileReader();
                        reader.onload = function (e) {
                            document.getElementById('profileImage').src = e.target.result;
                        }
                        reader.readAsDataURL(input.files[0]);
                    }
                }

                const Toast = Swal.mixin({
                    toast: true,
                    position: 'top',
                    showConfirmButton: false,
                    timer: 3000,
                    timerProgressBar: true,
                    didOpen: (toast) => {
                        toast.addEventListener('mouseenter', Swal.stopTimer)
                        toast.addEventListener('mouseleave', Swal.resumeTimer)
                    }
                });

                const flashData = document.getElementById('flash-data');
                const errorMsg = flashData.dataset.error;
                const successMsg = flashData.dataset.success;

                if (errorMsg && errorMsg.trim().length > 0) {
                    Toast.fire({
                        icon: 'error',
                        title: errorMsg
                    });
                }

                if (successMsg && successMsg.trim().length > 0) {
                    Toast.fire({
                        icon: 'success',
                        title: successMsg
                    });
                }

                function openEmailModal() {
                    document.getElementById('emailModal').classList.add('active');
                    document.body.style.overflow = 'hidden';
                }

                function closeEmailModal() {
                    document.getElementById('emailModal').classList.remove('active');
                    document.body.style.overflow = 'auto';
                }

                async function submitEmailChange() {
                    const newEmail = document.getElementById('newEmailInput').value.trim();
                    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

                    if (!emailRegex.test(newEmail)) {
                        Swal.fire('Error', 'Please enter a valid email address.', 'error');
                        return;
                    }

                    try {
                       
                        const response = await fetch('/user/profile/emailRequest', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ email: newEmail })
                        });

                        const result = await response.json();

                        if (response.ok) {
                            Swal.fire({
                                icon: 'success',
                                title: 'OTP Sent!',
                                text: 'Check your new email for the code.',
                                timer: 2000,
                                showConfirmButton: false
                            }).then(() => {
                                // Redirect to OTP verification page
                                window.location.href = '/user/profile/verifyEmail';
                            });
                        } else {
                            throw new Error(result.message || 'Failed to send OTP');
                        }
                    } catch (error) {
                        Swal.fire('Error', error.message, 'error');
                    }
                }

                async function updatePassword() {
                    const currentPassword = document.getElementById('currentPassword').value;
                    const newPassword = document.getElementById('newPassword').value;
                    const confirmPassword = document.getElementById('confirmPassword').value;

                    if (!currentPassword || !newPassword || !confirmPassword) {
                        Swal.fire('Error', 'All fields are required.', 'error');
                        return;
                    }

                    if (newPassword.length < 6) {
                        Swal.fire('Error', 'New password must be at least 6 characters.', 'error');
                        return;
                    }

                    if (newPassword !== confirmPassword) {
                        Swal.fire('Error', 'Passwords do not match.', 'error');
                        return;
                    }

                    try {
                        Swal.fire({
                            title: 'Updating password...',
                            allowOutsideClick: false,
                            didOpen: () => Swal.showLoading()
                        });

                        const response = await fetch('/user/profile/password', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ currentPassword, newPassword })
                        });

                        const result = await response.json();

                        if (response.ok) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Updated!',
                                text: 'Your password has been changed successfully.',
                                timer: 2000,
                                showConfirmButton: false
                            });
                            document.getElementById('passwordForm').reset();
                        } else {
                            throw new Error(result.message || 'Failed to update password');
                        }
                    } catch (error) {
                        Swal.fire('Error', error.message, 'error');
                    }
                }

                async function updateBasicInfo() {
                    const userName = document.getElementById('userName').value.trim();
                    const phoneNumber = document.getElementById('phoneNumber').value.trim();

                    if (!userName) {
                        Swal.fire('Error', 'Username is required', 'error');
                        return;
                    }

                    try {
                        Swal.fire({
                            title: 'Updating...',
                            allowOutsideClick: false,
                            didOpen: () => Swal.showLoading()
                        });

                        const response = await fetch('/user/profile/edit', {
                            method: 'PUT',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ userName, phoneNumber })
                        });

                        const result = await response.json();

                        if (response.ok) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Updated!',
                                text: result.message,
                                timer: 2000,
                                showConfirmButton: false
                            });
                        } else {
                            throw new Error(result.message);
                        }
                    } catch (error) {
                        Swal.fire('Error', error.message, 'error');
                    }
                }
            </script>
</body>

</html>
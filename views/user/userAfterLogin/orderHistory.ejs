<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZiGo | Order History</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="icon" type="image/png" href="/public/public/favicon.png">
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        :root {
            --primary-orange: #FF5A1F;
            --primary-orange-hover: #E44D18;
            --deep-black: #0F0F0F;
            --off-white: #F9F9F9;
            --dark-navy: #1E293B;
            --gray-light: #E2E8F0;
            --white: #FFFFFF;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--off-white);
            color: var(--dark-navy);
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* --- Profile Container --- */
        .profile-container {
            padding: 140px 5% 80px;
            max-width: 1400px;
            margin: 0 auto;
        }

        .profile-layout {
            display: grid;
            grid-template-columns: 320px 1fr;
            gap: 3rem;
        }

        @media (max-width: 1024px) {
            .profile-layout {
                grid-template-columns: 1fr;
            }
        }

        /* --- Sidebar --- */
        .profile-sidebar {
            background: white;
            border-radius: 32px;
            padding: 2.5rem;
            border: 1px solid var(--gray-light);
            height: min-content;
            position: sticky;
            top: 120px;
        }

        .user-info {
            text-align: center;
            margin-bottom: 2.5rem;
            padding-bottom: 2rem;
            border-bottom: 1px solid var(--gray-light);
        }

        .user-avatar-large {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            border: 4px solid var(--primary-orange);
            margin: 0 auto 1.5rem;
            overflow: hidden;
            box-shadow: 0 10px 20px rgba(255, 90, 31, 0.15);
        }

        .user-avatar-large img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .user-name {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--dark-navy);
        }

        .user-email {
            font-size: 0.9rem;
            opacity: 0.5;
        }

        .sidebar-nav {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 1.2rem;
            padding: 1.1rem 1.5rem;
            border-radius: 16px;
            text-decoration: none;
            color: var(--dark-navy);
            font-weight: 600;
            transition: var(--transition);
            cursor: pointer;
        }

        .sidebar-link i {
            font-size: 1.2rem;
            width: 24px;
            text-align: center;
            opacity: 0.4;
            transition: var(--transition);
        }

        .sidebar-link:hover {
            background: var(--off-white);
            color: var(--primary-orange);
        }

        .sidebar-link:hover i {
            opacity: 1;
            color: var(--primary-orange);
        }

        .sidebar-link.active {
            background: var(--primary-orange);
            color: white;
            box-shadow: 0 10px 20px rgba(255, 90, 31, 0.2);
        }

        .sidebar-link.active i {
            opacity: 1;
            color: white;
        }

        .logout-link {
            margin-top: 1rem;
            color: #ff4757;
        }

        .logout-link:hover {
            background: rgba(255, 71, 87, 0.1);
            color: #ff4757;
        }

        /* --- Content Panels --- */
        .panel-header {
            margin-bottom: 2.5rem;
        }

        .panel-title {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--dark-navy);
        }

        /* --- Order History Table --- */
        .order-card {
            background: white;
            border-radius: 24px;
            padding: 1.5rem;
            border: 1px solid var(--gray-light);
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            transition: var(--transition);
        }

        .order-card:hover {
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
            transform: translateY(-2px);
        }

        .order-status {
            padding: 4px 12px;
            border-radius: 100px;
            font-size: 0.75rem;
            font-weight: 700;
        }

        .status-delivered { background: #E7F9F0; color: #2ED573; }
        .status-processing { background: #FFF4E5; color: #FF9F43; }
        .status-shipped { background: #E0F2FE; color: #0EA5E9; }
        .status-cancelled { background: #FFEEEE; color: #FF4757; }
        .status-returned { background: #F3E8FF; color: #A855F7; }

        /* Pagination Styles */
        .pagination-container {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 0.5rem;
            margin-top: 3rem;
        }

        .pagination-btn {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: var(--transition);
            font-weight: 600;
            border: 1px solid var(--gray-light);
            background: white;
            color: var(--dark-navy);
            text-decoration: none;
        }

        .pagination-btn:hover {
            border-color: var(--primary-orange);
            color: var(--primary-orange);
        }

        .pagination-btn.active {
            background: var(--primary-orange);
            border-color: var(--primary-orange);
            color: white;
        }

        .order-mrp {
            font-size: 0.75rem;
            text-decoration: line-through;
            opacity: 0.4;
            display: block;
        }

        .order-discount {
            font-size: 0.65rem;
            color: #ff4757;
            font-weight: 700;
        }
    </style>
</head>

<body>
    <%- include('../../partials/header') %>

    <main class="profile-container">
        <div class="profile-layout">
            <!-- Sidebar -->
            <aside class="profile-sidebar">
                <div class="user-info">
                    <div class="user-avatar-large">
                        <% if (user && user.profileImage) { %>
                            <img src="<%= user.profileImage %>" alt="User Avatar">
                        <% } else { %>
                            <img src="https://ui-avatars.com/api/?name=<%= user.userName %>&background=FF5A1F&color=fff" alt="User Avatar">
                        <% } %>
                    </div>
                    <h2 class="user-name"><%= user.userName %></h2>
                    <p class="user-email"><%= user.email %></p>
                </div>

                <nav class="sidebar-nav">
                    <a href="/user/profile" class="sidebar-link">
                        <i class="fas fa-th-large"></i> Overview
                    </a>
                    <a href="/user/orders" class="sidebar-link active">
                        <i class="fas fa-shopping-bag"></i> Order History
                    </a>
                    <a href="/user/wallet" class="sidebar-link">
                        <i class="fas fa-wallet"></i> My Wallet
                    </a>
                    <a href="/user/wishlist" class="sidebar-link">
                        <i class="fas fa-heart"></i> Wishlist
                    </a>
                    <a href="/user/addresses" class="sidebar-link">
                        <i class="fas fa-map-marker-alt"></i> Addresses
                    </a>
                    <a href="/user/cart" class="sidebar-link">
                        <i class="fas fa-shopping-cart"></i> My Cart
                    </a>
                    <a href="/logout" class="sidebar-link logout-link">
                        <i class="fas fa-sign-out-alt"></i> Logout
                    </a>
                </nav>
            </aside>

            <!-- Main Content Area -->
            <div class="profile-content">
                <div id="orders-panel">
                    <div class="panel-header">
                        <h1 class="panel-title">Order <span class="text-orange-500">History</span></h1>
                    </div>
                    
                    <div class="space-y-4">
                        <% if (typeof orders !== 'undefined' && orders && orders.length > 0) { %>
                            <% orders.forEach(order => { %>
                                <div class="order-card p-6 md:p-8">
                                    <div class="flex items-center gap-6 md:gap-8">
                                        <div class="w-20 h-20 bg-gray-50 rounded-2xl p-2 flex items-center justify-center">
                                            <% if (order.items && order.items[0] && order.items[0].product && order.items[0].variant) { %>
                                                <img src="<%= order.items[0].variant.images[0] %>" alt="<%= order.items[0].product.productName %>" class="max-w-full max-h-full object-contain">
                                            <% } else { %>
                                                <img src="/public/landing/no-image.png" alt="No image" class="max-w-full max-h-full object-contain">
                                            <% } %>
                                        </div>
                                        <div>
                                            <p class="font-bold text-lg md:text-xl">
                                                <% if (order.items && order.items.length > 0) { %>
                                                    <%= order.items[0].product.productName %>
                                                    <%= order.items.length > 1 ? '(and ' + (order.items.length - 1) + ' more)' : '' %>
                                                <% } else { %>
                                                    Order <%= order.orderId %>
                                                <% } %>
                                            </p>
                                            <p class="text-sm opacity-50 mt-1">Order #<%= order.orderId %> | <%= new Date(order.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></p>
                                        </div>
                                    </div>
                                    <div class="text-right">
                                        <p class="text-xl font-black mb-0">₹<%= order.totalPrice.toLocaleString() %></p>
                                        <div class="flex flex-col items-end mb-2">
                                            <% if (order.discount && order.discount > 0) { %>
                                                <span class="order-mrp">₹<%= (order.totalPrice + order.discount).toLocaleString() %></span>
                                                <span class="order-discount text-xs">Discount Applied</span>
                                            <% } %>
                                        </div>
                                        <span class="order-status status-<%= order.status.toLowerCase() %>"><%= order.status %></span>
                                        <a href="/user/orders/<%= order._id %>" class="block mt-4 text-xs font-bold text-orange-500 hover:underline">View Details</a>
                                        <% if (order.status === 'Delivered') { %>
                                            <button class="block w-full mt-2 text-xs font-bold text-orange-500 hover:underline">Download Invoice</button>
                                        <% } %>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="bg-white p-12 rounded-[32px] border border-dashed border-gray-300 text-center">
                                <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6 text-gray-300">
                                    <i class="fas fa-shopping-bag text-3xl"></i>
                                </div>
                                <h2 class="text-2xl font-bold mb-4">No orders yet</h2>
                                <p class="text-gray-500 mb-8">You haven't placed any orders yet. Start shopping to fill your history!</p>
                                <a href="/shop" class="bg-orange-500 text-white px-10 py-4 rounded-2xl font-bold hover:bg-orange-600 transition-all inline-block">Start Shopping</a>
                            </div>
                        <% } %>
                    </div>

                    <!-- Pagination -->
                    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
                        <div class="pagination-container">
                            <% if (currentPage > 1) { %>
                                <a href="/user/orders?page=<%= currentPage - 1 %>" class="pagination-btn"><i class="fas fa-chevron-left"></i></a>
                            <% } %>
                            
                            <% for(let i = 1; i <= totalPages; i++) { %>
                                <% if (i === currentPage) { %>
                                    <a href="#" class="pagination-btn active"><%= i %></a>
                                <% } else { %>
                                    <a href="/user/orders?page=<%= i %>" class="pagination-btn"><%= i %></a>
                                <% } %>
                            <% } %>

                            <% if (currentPage < totalPages) { %>
                                <a href="/user/orders?page=<%= currentPage + 1 %>" class="pagination-btn"><i class="fas fa-chevron-right"></i></a>
                            <% } %>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </main>

    <%- include('../../partials/footer') %>
</body>

</html>

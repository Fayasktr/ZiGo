<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZiGo | My Account</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="icon" type="image/png" href="/public/public/favicon.png">
    <style>
        :root {
            --primary-orange: #FF5A1F;
            --primary-orange-hover: #E44D18;
            --deep-black: #0F0F0F;
            --off-white: #F9F9F9;
            --dark-navy: #1E293B;
            --gray-light: #E2E8F0;
            --white: #FFFFFF;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--off-white);
            color: var(--dark-navy);
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* --- Profile Container --- */
        .profile-container {
            padding: 140px 5% 80px;
            max-width: 1400px;
            margin: 0 auto;
        }

        .profile-layout {
            display: grid;
            grid-template-columns: 320px 1fr;
            gap: 3rem;
        }

        @media (max-width: 1024px) {
            .profile-layout {
                grid-template-columns: 1fr;
            }
        }

        /* --- Sidebar --- */
        .profile-sidebar {
            background: white;
            border-radius: 32px;
            padding: 2.5rem;
            border: 1px solid var(--gray-light);
            height: min-content;
            position: sticky;
            top: 120px;
        }

        .user-info {
            text-align: center;
            margin-bottom: 2.5rem;
            padding-bottom: 2rem;
            border-bottom: 1px solid var(--gray-light);
        }

        .user-avatar-large {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            border: 4px solid var(--primary-orange);
            margin: 0 auto 1.5rem;
            overflow: hidden;
            box-shadow: 0 10px 20px rgba(255, 90, 31, 0.15);
        }

        .user-avatar-large img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .user-name {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--dark-navy);
        }

        .user-email {
            font-size: 0.9rem;
            opacity: 0.5;
        }

        .sidebar-nav {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 1.2rem;
            padding: 1.1rem 1.5rem;
            border-radius: 16px;
            text-decoration: none;
            color: var(--dark-navy);
            font-weight: 600;
            transition: var(--transition);
            cursor: pointer;
        }

        .sidebar-link i {
            font-size: 1.2rem;
            width: 24px;
            text-align: center;
            opacity: 0.4;
            transition: var(--transition);
        }

        .sidebar-link:hover {
            background: var(--off-white);
            color: var(--primary-orange);
        }

        .sidebar-link:hover i {
            opacity: 1;
            color: var(--primary-orange);
        }

        .sidebar-link.active {
            background: var(--primary-orange);
            color: white;
            box-shadow: 0 10px 20px rgba(255, 90, 31, 0.2);
        }

        .sidebar-link.active i {
            opacity: 1;
            color: white;
        }

        .logout-link {
            margin-top: 1rem;
            color: #ff4757;
        }

        .logout-link:hover {
            background: rgba(255, 71, 87, 0.1);
            color: #ff4757;
        }

        /* --- Content Panels --- */
        .panel-header {
            margin-bottom: 2.5rem;
        }

        .panel-title {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--dark-navy);
        }

        /* --- Form Elements --- */
        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-label {
            display: block;
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            opacity: 0.4;
            margin-bottom: 0.5rem;
        }

        .form-input {
            width: 100%;
            padding: 1rem 1.5rem;
            border-radius: 16px;
            border: 2px solid var(--gray-light);
            font-weight: 600;
            outline: none;
            transition: var(--transition);
        }

        .form-input:focus {
            border-color: var(--primary-orange);
            box-shadow: 0 0 0 4px rgba(255, 90, 31, 0.1);
        }

        .save-btn {
            width: 100%;
            background: var(--deep-black);
            color: white;
            padding: 1.2rem;
            border-radius: 20px;
            font-weight: 800;
            transition: var(--transition);
            border: none;
            cursor: pointer;
        }

        .save-btn:hover {
            background: var(--primary-orange);
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(255, 90, 31, 0.2);
        }

        /* --- Modal Overlays --- */
        .wallet-modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(8px);
            z-index: 2000;
            display: none;
            justify-content: center;
            align-items: center;
            padding: 1.5rem;
        }

        .wallet-modal {
            background: white;
            width: 100%;
            max-width: 450px;
            border-radius: 32px;
            padding: 2.5rem;
            position: relative;
            animation: modalPop 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        @keyframes modalPop {
            from {
                transform: scale(0.9);
                opacity: 0;
            }

            to {
                transform: scale(1);
                opacity: 1;
            }
        }
    </style>
</head>

<body>
    <%- include('../../partials/header') %>

        <main class="profile-container">
            <div class="profile-layout">
                <!-- Sidebar -->
                <aside class="profile-sidebar">
                    <div class="user-info">
                        <div class="user-avatar-large">
                            <img src="<%= (user.profileImage) ? user.profileImage : 'https://ui-avatars.com/api/?name=' + user.userName + '&background=FF5A1F&color=fff' %>"
                                alt="User Avatar">
                        </div>
                        <h2 class="user-name">
                            <%= user.userName %>
                        </h2>
                        <p class="user-email">
                            <%= user.email %>
                        </p>
                    </div>

                    <nav class="sidebar-nav">
                        <a href="/profile" class="sidebar-link active">
                            <i class="fas fa-th-large"></i> Overview
                        </a>
                        <a href="/orders" class="sidebar-link">
                            <i class="fas fa-shopping-bag"></i> Order History
                        </a>
                        <a href="/wallet" class="sidebar-link">
                            <i class="fas fa-wallet"></i> My Wallet
                        </a>
                        <a href="/wishlist" class="sidebar-link">
                            <i class="fas fa-heart"></i> Wishlist
                        </a>
                        <a href="/addresses" class="sidebar-link">
                            <i class="fas fa-map-marker-alt"></i> Addresses
                        </a>
                        <a href="/cart" class="sidebar-link">
                            <i class="fas fa-shopping-cart"></i> My Cart
                        </a>
                        <a href="/logout" class="sidebar-link logout-link">
                            <i class="fas fa-sign-out-alt"></i> Logout
                        </a>
                    </nav>
                </aside>

                <!-- Main Content Area -->
                <div class="profile-content">
                    <!-- Overview Panel -->
                    <div id="overview-panel">
                        <div class="panel-header">
                            <h1 class="panel-title">Account <span class="text-orange-500">Overview</span></h1>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
                            <div class="bg-white p-8 rounded-[32px] border border-gray-100">
                                <h3 class="text-lg font-bold mb-4 opacity-40 uppercase tracking-widest">Personal Details
                                </h3>
                                <p class="text-xl font-bold">
                                    <%= user.userName %>
                                </p>
                                <p class="opacity-60 mb-6">
                                    <%= user.email %>
                                </p>
                                <button onclick="openEditProfileModal()"
                                    class="text-orange-500 font-bold text-sm hover:underline">Edit Profile</button>
                            </div>
                            <div class="bg-white p-8 rounded-[32px] border border-gray-100">
                                <h3 class="text-lg font-bold mb-4 opacity-40 uppercase tracking-widest">Default Address
                                </h3>
                                <% if (typeof address !=='undefined' && address) { %>
                                    <p class="font-bold">
                                        <%= address.label %>
                                    </p>
                                    <p class="opacity-60 text-sm mb-6">
                                        <%= address.fullAddress %>
                                    </p>
                                    <% } else { %>
                                        <p class="opacity-60 text-sm mb-6">No default address set.</p>
                                        <% } %>
                                            <a href="/addresses"
                                                class="text-orange-500 font-bold text-sm hover:underline">Manage
                                                Addresses</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <%- include('../../partials/footer') %>

            <!-- Edit Profile Modal -->
            <div id="editProfileModal" class="wallet-modal-overlay">
                <div class="wallet-modal">
                    <button onclick="closeModal('editProfileModal')"
                        class="absolute top-6 right-6 text-gray-400 hover:text-black">
                        <i class="fas fa-times text-xl"></i>
                    </button>
                    <h2 class="text-2xl font-black mb-1">Edit Profile</h2>
                    <p class="text-sm opacity-50 mb-8">Update your personal information</p>

                    <form action="/profile/edit" method="POST">
                        <div class="form-group">
                            <label class="form-label">User Name</label>
                            <input type="text" name="userName" class="form-input" value="<%= user.userName %>">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Email Address</label>
                            <input type="email" name="email" class="form-input" value="<%= user.email %>" readonly>
                            <p class="text-[10px] opacity-40 mt-1">Email cannot be changed directly.</p>
                        </div>
                        <!-- Add other fields as needed matching your User model -->
                        <button type="submit" class="save-btn mt-4">Save Changes</button>
                    </form>
                </div>
            </div>

            <script>
                function openEditProfileModal() {
                    document.getElementById('editProfileModal').style.display = 'flex';
                }

                function closeModal(id) {
                    document.getElementById(id).style.display = 'none';
                }
            </script>
</body>

</html>
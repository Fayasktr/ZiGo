<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZiGo | Fast Tech. Smart Prices.</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="icon" type="image/png" href="/public/public/favicon.png">
    <style>
        :root {
            --primary-orange: #FF5A1F;
            --primary-orange-hover: #E44D18;
            --deep-black: #0F0F0F;
            --off-white: #F9F9F9;
            --dark-navy: #1E293B;
            --gray-light: #E2E8F0;
            --white: #FFFFFF;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--off-white);
            color: var(--dark-navy);
            overflow-x: hidden;
        }

        /* --- Hero Section --- */
        .hero {
            min-height: 800px;
            background-color: var(--deep-black);
            background-image:
                radial-gradient(circle at 80% 20%, rgba(255, 90, 31, 0.15) 0%, transparent 40%),
                radial-gradient(circle at 20% 80%, rgba(255, 90, 31, 0.05) 0%, transparent 40%),
                linear-gradient(to bottom, transparent, rgba(15, 15, 15, 0.8));
            padding: 0;
            color: var(--white);
            position: relative;
            overflow: hidden;
        }

        .hero::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: url('https://www.transparenttextures.com/patterns/stardust.png');
            opacity: 0.1;
            pointer-events: none;
        }

        .hero-content {
            flex: 1.2;
            z-index: 100;
        }

        .hero-content h1 {
            font-weight: 800;
            line-height: 1.1;
            margin-bottom: 1.5rem;
            letter-spacing: -2px;
        }

        .hero-content h1 span {
            color: var(--primary-orange);
            display: block;
            text-shadow: 0 0 30px rgba(255, 90, 31, 0.3);
        }

        .hero-content p {
            font-size: 1.25rem;
            opacity: 0.8;
            max-width: 500px;
            margin-bottom: 2.5rem;
            font-weight: 300;
        }

        .hero-btns {
            display: flex;
            gap: 1.5rem;
        }

        .btn {
            padding: 1rem 2.5rem;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 700;
            font-size: 1rem;
            transition: var(--transition);
            display: inline-block;
        }

        .btn-primary {
            background-color: var(--primary-orange);
            color: white;
            border: 2px solid var(--primary-orange);
        }

        .btn-primary:hover {
            background-color: var(--primary-orange-hover);
            border-color: var(--primary-orange-hover);
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(255, 90, 31, 0.3);
        }

        .btn-secondary {
            background-color: transparent;
            color: white;
            border: 2px solid rgba(255, 255, 255, 0.2);
        }

        .btn-secondary:hover {
            border-color: var(--white);
            background-color: rgba(255, 255, 255, 0.05);
            transform: translateY(-5px);
        }

        .hero-visual {
            flex: 1;
            display: flex;
            justify-content: flex-end;
            z-index: 100;
        }

        .hero-visual img {
            max-width: 85%;
            height: auto;
            object-fit: cover;
            border-radius: 32px;
            box-shadow: 0 20px 100px rgba(255, 90, 31, 0.45), 0 0 40px rgba(255, 90, 31, 0.2);
            filter: brightness(1.05);
            animation: float 6s ease-in-out infinite;
        }

        @keyframes float {
            0% {
                transform: translateY(0px);
            }

            50% {
                transform: translateY(-20px);
            }

            100% {
                transform: translateY(0px);
            }
        }

        /* --- Trust Strip --- */
        .trust-strip {
            padding: 4rem 0;
            background-color: var(--white);
            border-bottom: 1px solid var(--gray-light);
        }

        .trust-item {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .trust-icon {
            width: 48px;
            height: 48px;
            background-color: rgba(255, 90, 31, 0.1);
            border-radius: 12px;
            display: flex;
            justify-content: center;
            align-items: center;
            color: var(--primary-orange);
            font-size: 1.5rem;
            transition: var(--transition);
        }

        .trust-item:hover .trust-icon {
            background-color: var(--primary-orange);
            color: white;
            transform: scale(1.1);
        }

        .trust-text h4 {
            font-size: 1rem;
            font-weight: 700;
        }

        .trust-text p {
            font-size: 0.85rem;
            opacity: 0.6;
        }

        /* --- Category Showcase --- */
        .categories {
            padding: 8rem 0;
        }

        .section-header {
            text-align: center;
            margin-bottom: 4rem;
        }

        .section-header h2 {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 1rem;
        }

        .section-header p {
            color: var(--dark-navy);
            opacity: 0.6;
            font-size: 1.1rem;
        }

        .category-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 2rem;
        }

        .category-card {
            background-color: var(--white);
            border-radius: 20px;
            padding: 2rem;
            text-align: center;
            text-decoration: none;
            color: var(--dark-navy);
            transition: var(--transition);
            border: 1px solid var(--gray-light);
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .category-card:hover {
            transform: translateY(-10px);
            border-color: var(--primary-orange);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
        }

        .category-image {
            width: 100%;
            height: 200px;
            margin-bottom: 1.5rem;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .category-image img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
            transition: var(--transition);
        }

        .category-card:hover .category-image img {
            transform: scale(1.1);
        }

        .category-card h3 {
            font-size: 1.25rem;
            font-weight: 700;
        }

        /* --- Featured Products --- */
        .featured-products {
            padding: 0 0 8rem;
        }

        .product-grid {
            display: grid;
        }

        .product-card {
            background-color: var(--white);
            border-radius: 24px;
            overflow: hidden;
            border: 1px solid var(--gray-light);
            transition: var(--transition);
            position: relative;
        }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.08);
        }

        .product-img-wrapper {
            width: 100%;
            height: 300px;
            background-color: #fcfcfc;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 2rem;
        }

        .product-img-wrapper img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

        .product-info {
            padding: 1.5rem;
        }

        .product-category {
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            color: var(--primary-orange);
            letter-spacing: 1px;
            margin-bottom: 0.5rem;
            display: block;
        }

        .product-title {
            font-size: 1.15rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            color: var(--dark-navy);
        }

        .product-price {
            font-size: 1.15rem;
            font-weight: 800;
            color: var(--dark-navy);
        }

        .add-to-cart-btn {
            position: absolute;
            bottom: 1.5rem;
            right: 1.5rem;
            width: 44px;
            height: 44px;
            background-color: var(--dark-navy);
            color: white;
            border-radius: 12px;
            display: flex;
            justify-content: center;
            align-items: center;
            border: none;
            cursor: pointer;
            transition: var(--transition);
        }

        .add-to-cart-btn:hover {
            background-color: var(--primary-orange);
            transform: rotate(90deg);
        }

        /* --- Why ZiGo --- */
        .why-zigo {
            padding: 8rem 0;
            background-color: var(--deep-black);
            color: var(--white);
        }

        .why-grid {
            display: grid;
        }

        .why-item {
            text-align: center;
        }

        .why-icon {
            font-size: 3rem;
            margin-bottom: 2rem;
            display: inline-block;
        }

        .why-item h3 {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 1rem;
        }

        .why-item p {
            opacity: 0.7;
            font-size: 1rem;
            line-height: 1.8;
        }

        /* --- Brands Strip --- */
        .brands-strip {
            padding: 4rem 0;
            background-color: var(--white);
            border-bottom: 1px solid var(--gray-light);
        }

        .brands-container {
            display: flex;
            align-items: center;
        }

        .brands-container:hover {
            opacity: 1;
            filter: grayscale(0);
        }

        .brand-logo {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--dark-navy);
        }

        /* --- User Reviews --- */
        .reviews {
            padding: 8rem 0;
        }

        .reviews-grid {
            display: grid;
        }

        .review-card {
            background-color: var(--white);
            padding: 2.5rem;
            border-radius: 24px;
            border: 1px solid var(--gray-light);
            transition: var(--transition);
        }

        .review-card:hover {
            border-color: var(--primary-orange);
            transform: translateY(-5px);
        }

        .stars {
            color: var(--primary-orange);
            margin-bottom: 1rem;
            font-size: 1.2rem;
        }

        .review-text {
            font-style: italic;
            margin-bottom: 1.5rem;
            line-height: 1.7;
        }

        .reviewer-info {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .reviewer-avatar {
            width: 40px;
            height: 40px;
            background-color: var(--gray-light);
            border-radius: 50%;
        }

        .reviewer-name {
            font-weight: 700;
            font-size: 0.95rem;
        }

        /* --- Newsletter --- */
        .newsletter {
            padding: 6rem 0;
            background-color: var(--primary-orange);
            color: var(--white);
            text-align: center;
        }

        .newsletter h2 {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 1rem;
        }

        .newsletter p {
            font-size: 1.1rem;
            opacity: 0.9;
            margin-bottom: 2.5rem;
        }

        .newsletter-form {
            margin: 0 auto;
        }

        .newsletter-form input {
            flex: 1;
            padding: 1rem 1.5rem;
            border-radius: 12px;
            border: none;
            font-size: 1rem;
            outline: none;
        }

        .newsletter-form button {
            background-color: var(--deep-black);
            color: var(--white);
            padding: 1rem 2rem;
            border-radius: 12px;
            border: none;
            font-weight: 700;
            cursor: pointer;
            transition: var(--transition);
        }

        .newsletter-form button:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
        }

        /* --- Footer --- */
        footer {
            background-color: var(--deep-black);
            color: var(--white);
            padding: 6rem 0 2rem;
        }

        .footer-grid {
            display: grid;
        }

        .footer-col h4 {
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 2rem;
            color: var(--white);
        }

        .footer-col p {
            opacity: 0.6;
            margin-bottom: 2rem;
            line-height: 1.7;
        }

        .footer-links {
            list-style: none;
        }

        .footer-links li {
            margin-bottom: 1rem;
        }

        .footer-links a {
            color: var(--white);
            text-decoration: none;
            opacity: 0.6;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .footer-links a:hover {
            opacity: 1;
            color: var(--primary-orange);
            transform: translateX(5px);
        }

        .footer-thumb {
            width: 40px;
            height: 40px;
            background-color: var(--white);
            border-radius: 8px;
            padding: 4px;
            object-fit: contain;
        }

        .social-links {
            display: flex;
            gap: 1.5rem;
        }

        .social-links a {
            color: var(--white);
            font-size: 1.5rem;
            opacity: 0.6;
            transition: var(--transition);
        }

        .social-links a:hover {
            opacity: 1;
            color: var(--primary-orange);
        }

        .footer-bottom {
            padding-top: 2rem;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
            opacity: 0.4;
            font-size: 0.85rem;
        }

        /* --- Animations --- */
        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s ease-out;
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        [data-delay="200"] {
            transition-delay: 200ms;
        }

        [data-delay="400"] {
            transition-delay: 400ms;
        }

        [data-delay="600"] {
            transition-delay: 600ms;
        }
    </style>
</head>

<body>

    <%- include('../../partials/header') %>


        <main>
            <!-- Hero Section -->
            <section class="hero flex flex-col lg:flex-row items-center text-center lg:text-left pt-48 pb-32">
                <div class="max-w-6xl mx-auto px-5 w-full flex flex-col lg:flex-row items-center gap-12">
                    <div class="hero-content">
                        <h1 class="text-4xl md:text-6xl lg:text-8xl">Fast Tech. <span>Smart Prices.</span></h1>
                        <p class="mx-auto lg:mx-0">Phones, smart watches & accessories — delivered faster than you
                            expect.
                            Premium quality at prices
                            that make sense.</p>
                        <div class="hero-btns flex flex-col sm:flex-row justify-center lg:justify-start">
                            <a href="/shop" class="btn btn-primary">Shop Now</a>
                            <a href="/shop" class="btn btn-secondary">Browse Categories</a>
                        </div>
                    </div>
                    <div class="hero-visual w-full flex justify-center lg:justify-end">
                        <img src="/public/landing/hero_premium.png" alt="Premium Tech Showcase"
                            class="w-[85%] max-w-[500px]">
                    </div>
                </div>
            </section>

            <!-- Brands Strip -->
            <section class="brands-strip overflow-hidden">
                <div class="max-w-6xl mx-auto px-5">
                    <div class="brands-container flex flex-wrap justify-center gap-8 md:gap-16 items-center">
                        <img src="https://placehold.co/120x40/transparent/333?text=APPLE" alt="Apple"
                            class="h-8 md:h-10 opacity-60 hover:opacity-100 transition-opacity cursor-pointer">
                        <img src="https://placehold.co/120x40/transparent/333?text=SAMSUNG" alt="Samsung"
                            class="h-8 md:h-10 opacity-60 hover:opacity-100 transition-opacity cursor-pointer">
                        <img src="https://placehold.co/120x40/transparent/333?text=NOISE" alt="Noise"
                            class="h-8 md:h-10 opacity-60 hover:opacity-100 transition-opacity cursor-pointer">
                        <img src="https://placehold.co/120x40/transparent/333?text=BOAT" alt="Boat"
                            class="h-8 md:h-10 opacity-60 hover:opacity-100 transition-opacity cursor-pointer">
                        <img src="https://placehold.co/120x40/transparent/333?text=ONEPLUS" alt="OnePlus"
                            class="h-8 md:h-10 opacity-60 hover:opacity-100 transition-opacity cursor-pointer">
                    </div>
                </div>
            </section>

            <!-- Category Showcase -->
            <section class="categories reveal">
                <div class="max-w-6xl mx-auto px-5">
                    <div class="section-header">
                        <h2>Shop by Category</h2>
                        <p>Everything you need, organized perfectly.</p>
                    </div>
                    <div class="category-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                        <a href="/shop?category=smartphones" class="category-card">
                            <div class="category-image">
                                <img src="/public/landing/smartphone.png" alt="Smartphones">
                            </div>
                            <h3>Smartphones</h3>
                        </a>
                        <a href="/shop?category=watches" class="category-card">
                            <div class="category-image">
                                <img src="/public/landing/watch.png" alt="Smart Watches">
                            </div>
                            <h3>Smart Watches</h3>
                        </a>
                        <a href="/shop?category=headsets" class="category-card">
                            <div class="category-image">
                                <img src="/public/landing/headset.png" alt="Headsets">
                            </div>
                            <h3>Headsets</h3>
                        </a>
                        <a href="/shop?category=accessories" class="category-card">
                            <div class="category-image">
                                <img src="/public/landing/accessories.png" alt="Accessories">
                            </div>
                            <h3>Accessories</h3>
                        </a>
                    </div>
                </div>
            </section>

            <!-- Featured Products -->
            <section class="featured-products reveal">
                <div class="max-w-6xl mx-auto px-5">
                    <div class="section-header">
                        <h2>Featured Products</h2>
                        <p>Handpicked tech for your lifestyle.</p>
                    </div>
                    <div class="product-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                        <!-- Product 1 -->
                        <div class="product-card">
                            <div class="product-img-wrapper">
                                <img src="/public/landing/neo2.png" alt="ZiGo Neo 1 Flagship">
                            </div>
                            <div class="product-info">
                                <span class="product-category">Smartphone</span>
                                <h3 class="product-title">ZiGo Neo 1 Flagship</h3>
                                <p class="product-price">₹82,339.00</p>
                                <button class="add-to-cart-btn">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <line x1="12" y1="5" x2="12" y2="19"></line>
                                        <line x1="5" y1="12" x2="19" y2="12"></line>
                                    </svg>
                                </button>
                            </div>
                        </div>
                        <!-- Product 2 -->
                        <div class="product-card">
                            <div class="product-img-wrapper">
                                <img src="/public/landing/watch_pro.png" alt="ZiGo Watch S Series">
                            </div>
                            <div class="product-info">
                                <span class="product-category">Smart Watch</span>
                                <h3 class="product-title">ZiGo Watch S Series</h3>
                                <p class="product-price">₹22,805.00</p>
                                <button class="add-to-cart-btn">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <line x1="12" y1="5" x2="12" y2="19"></line>
                                        <line x1="5" y1="12" x2="19" y2="12"></line>
                                    </svg>
                                </button>
                            </div>
                        </div>
                        <!-- Product 3 -->
                        <div class="product-card">
                            <div class="product-img-wrapper">
                                <img src="/public/landing/headset_elite.png" alt="ZiGo Aura Elite">
                            </div>
                            <div class="product-info">
                                <span class="product-category">Audio</span>
                                <h3 class="product-title">ZiGo Aura Elite</h3>
                                <p class="product-price">₹18,226.00</p>
                                <button class="add-to-cart-btn">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <line x1="12" y1="5" x2="12" y2="19"></line>
                                        <line x1="5" y1="12" x2="19" y2="12"></line>
                                    </svg>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Why ZiGo -->
            <section class="why-zigo reveal">
                <div class="max-w-6xl mx-auto px-5">
                    <div class="section-header">
                        <h2 style="color: white;">Why Choose ZiGo?</h2>
                        <p style="color: rgba(255,255,255,0.6);">Beyond the specs, it's about the experience.</p>
                    </div>
                    <div class="why-grid grid grid-cols-1 lg:grid-cols-3 gap-12">
                        <div class="why-item">
                            <div class="why-icon">⚡</div>
                            <h3>Speed-First Delivery</h3>
                            <p>We believe waiting is the hardest part. Our logistics network ensures your new tech
                                reaches
                                you
                                in record time.</p>
                        </div>
                        <div class="why-item">
                            <div class="why-icon">🧠</div>
                            <h3>Curated Electronics</h3>
                            <p>We don't sell everything; we sell the best. Every product is handpicked for quality,
                                performance,
                                and value.</p>
                        </div>
                        <div class="why-item">
                            <div class="why-icon">🛠️</div>
                            <h3>Quality Checked</h3>
                            <p>Peace of mind comes standard. Every device undergoes a rigorous quality check before it
                                leaves
                                our warehouse.</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Trust Strip (Moved from top) -->
            <section class="trust-strip">
                <div class="max-w-6xl mx-auto px-5 grid grid-cols-2 lg:grid-cols-4 gap-8">
                    <div class="trust-item">
                        <div class="trust-icon">⚡</div>
                        <div class="trust-text">
                            <h4>Fast Delivery</h4>
                            <p>Within 48-72 hours</p>
                        </div>
                    </div>
                    <div class="trust-item">
                        <div class="trust-icon">🔒</div>
                        <div class="trust-text">
                            <h4>Secure Payments</h4>
                            <p>100% encrypted</p>
                        </div>
                    </div>
                    <div class="trust-item">
                        <div class="trust-icon">🔄</div>
                        <div class="trust-text">
                            <h4>Easy Returns</h4>
                            <p>7-day replacement</p>
                        </div>
                    </div>
                    <div class="trust-item">
                        <div class="trust-icon">⭐</div>
                        <div class="trust-text">
                            <h4>Verified Products</h4>
                            <p>Original brand gear</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- User Reviews -->
            <section class="reviews reveal">

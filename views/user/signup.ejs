<style>
    /* Unique Styles for Signup Page to complement main.hbs */
    .signup-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: var(--deep-black);
        padding: 2rem;
        position: relative;
        overflow: hidden;
    }

    .signup-container::before {
        content: '';
        position: absolute;
        width: 1000px;
        height: 1000px;
        background: radial-gradient(circle, rgba(255, 90, 31, 0.1) 0%, transparent 70%);
        bottom: -500px;
        left: -500px;
        z-index: 1;
    }

    .signup-card {
        width: 100%;
        max-width: 1200px;
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 32px;
        display: flex;
        overflow: hidden;
        z-index: 2;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .signup-visual {
        flex: 1;
        background: url('/public/signup/signup-bg.png') center/cover no-repeat;
        display: none;
        position: relative;
    }

    .signup-visual::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to right, rgba(15, 15, 15, 0.9), transparent);
    }

    @media (min-width: 1024px) {
        .signup-visual {
            display: block;
        }
    }

    .signup-form-side {
        flex: 1.2;
        padding: 3rem 4rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        color: var(--white);
    }

    .signup-header {
        margin-bottom: 2rem;
    }

    .signup-header h2 {
        font-size: 2.5rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
        background: linear-gradient(to right, #fff, var(--primary-orange));
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .signup-header p {
        opacity: 0.6;
        font-size: 1rem;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }

    @media (max-width: 640px) {
        .form-grid {
            grid-template-columns: 1fr;
        }
    }

    .form-group {
        margin-bottom: 1rem;
    }

    .form-group.full-width {
        grid-column: span 2;
    }

    @media (max-width: 640px) {
        .form-group.full-width {
            grid-column: span 1;
        }
    }

    .form-group label {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        opacity: 0.8;
    }

    .input-wrapper input {
        width: 100%;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 0.9rem 1.2rem;
        border-radius: 12px;
        color: white;
        font-size: 0.95rem;
        outline: none;
        transition: var(--transition);
    }

    .input-wrapper input:focus {
        border-color: var(--primary-orange);
        background: rgba(255, 255, 255, 0.08);
        box-shadow: 0 0 0 4px rgba(255, 90, 31, 0.1);
    }

    .terms-check {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        margin: 1rem 0;
        font-size: 0.85rem;
        opacity: 0.7;
    }

    .terms-check input {
        margin-top: 0.25rem;
        accent-color: var(--primary-orange);
    }

    .signup-btn {
        width: 100%;
        background: var(--primary-orange);
        color: white;
        border: none;
        padding: 1.1rem;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: var(--transition);
        margin-top: 1rem;
    }

    .social-divider {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin: 1.5rem 0;
        opacity: 0.3;
        font-size: 0.8rem;
    }

    .social-divider::before,
    .social-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: white;
    }

    .social-btns {
        display: flex;
        gap: 1rem;
    }

    .social-btn {
        flex: 1;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 0.8rem;
        border-radius: 12px;
        color: white;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        transition: var(--transition);
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
    }

    .login-link {
        text-align: center;
        margin-top: 2rem;
        font-size: 0.95rem;
        opacity: 0.7;
    }

    .login-link a {
        color: var(--primary-orange);
        text-decoration: none;
        font-weight: 700;
    }
</style>

<div class="signup-container">
    <div class="signup-card reveal">
        <div class="signup-visual">
            <div class="absolute bottom-12 left-12 z-10 p-8">
                <h3 class="text-3xl font-extrabold text-white mb-2">Join ZiGo.</h3>
                <p class="text-white/60">The next generation of tech shopping starts inspired by you.</p>
            </div>
        </div>

        <div class="signup-form-side">
            <div class="signup-header text-center lg:text-left">
                <h2>Create Account</h2>
                <p>Be part of the tech revolution.</p>
            </div>

            <form action="/register" method="POST">
                <div class="form-grid">
                    <div class="form-group full-width">
                        <label for="username">Username</label>
                        <div class="input-wrapper">
                            <input type="text" id="username" name="username" placeholder="johndoe123" required>
                        </div>
                    </div>
                    <div class="form-group full-width">
                        <label for="email">Email Address</label>
                        <div class="input-wrapper">
                            <input type="email" id="email" name="email" placeholder="john@example.com" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="password">Password</label>
                        <div class="input-wrapper">
                            <input type="password" id="password" name="password" placeholder="••••••••" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="confirmPassword">Confirm Password</label>
                        <div class="input-wrapper">
                            <input type="password" id="confirmPassword" name="confirmPassword" placeholder="••••••••"
                                required>
                        </div>
                    </div>
                    <div class="form-group full-width">
                        <label for="referralCode">Referral Code (Optional)</label>
                        <div class="input-wrapper">
                            <input type="text" id="referralCode" name="referralCode" placeholder="ZIGO-XXXXXX">
                        </div>
                        <div class="flex items-center gap-2 mt-2">
                            <div class="w-1.5 h-1.5 rounded-full bg-[#FF5A1F]"></div>
                            <p class="text-[0.7rem] font-bold text-[#FF5A1F] uppercase tracking-wider">Friend Bonus: Get
                                ₹2,300 ZiGo Credits</p>
                        </div>
                    </div>
                </div>

                <div class="terms-check">
                    <input type="checkbox" id="terms" name="terms" required>
                    <label for="terms">I agree to the <a href="/terms" class="text-[#FF5A1F] font-bold">Terms</a> and <a
                            href="/privacy" class="text-[#FF5A1F] font-bold">Privacy</a>.</label>
                </div>

                <button type="submit" class="signup-btn">Create Your ZiGo Account</button>
            </form>

            <div class="social-divider">Or join with</div>
            <div class="social-btns flex flex-col sm:flex-row gap-4">
                <button class="social-btn w-full">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path
                            d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                            fill="#4285F4" />
                        <path
                            d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                            fill="#34A853" />
                        <path
                            d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                            fill="#FBBC05" />
                        <path
                            d="M12 5.38c1.62 0 3.06.56 4.21 1.66l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                            fill="#EA4335" />
                    </svg>
                    Google
                </button>
            </div>

            <p class="login-link">
                Already a member? <a href="/login">Sign In</a>
            </p>
        </div>
    </div>
</div>

<script>
    // Add active class to trigger the reveal animation
    window.addEventListener('load', () => {
        document.querySelector('.signup-card').classList.add('active');
    });
</script>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZiGo | Join the Revolution</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="icon" type="image/png" href="/public/public/favicon.png">
    <style>
        :root {
            --primary-orange: #FF5A1F;
            --primary-orange-hover: #E44D18;
            --deep-black: #0F0F0F;
            --off-white: #F9F9F9;
            --dark-navy: #1E293B;
            --gray-light: #E2E8F0;
            --white: #FFFFFF;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--deep-black);
            color: var(--white);
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* --- Global Header --- */
        header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.28rem 5%;
            z-index: 1000;
            transition: var(--transition);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .logo img.icon {
            height: 95px;
            width: auto;
        }

        .logo img.name {
            height: 47px;
            width: auto;
            margin-top: 2px;
        }

        /* --- Signup Section --- */
        .signup-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: var(--deep-black);
            padding: 2rem;
            position: relative;
            padding-top: 100px;
        }

        .signup-container::before {
            content: '';
            position: absolute;
            width: 1000px;
            height: 1000px;
            background: radial-gradient(circle, rgba(255, 90, 31, 0.1) 0%, transparent 70%);
            bottom: -500px;
            left: -500px;
            z-index: 1;
        }

        .signup-card {
            width: 100%;
            max-width: 1200px;
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 32px;
            display: flex;
            overflow: hidden;
            z-index: 2;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .signup-card.active {
            opacity: 1;
            transform: translateY(0);
        }

        .signup-visual {
            flex: 1;
            background: url('/public/signup/signup-bg.png') center/cover no-repeat;
            display: none;
            position: relative;
        }

        .signup-visual::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to right, rgba(15, 15, 15, 0.9), transparent);
        }

        @media (min-width: 1024px) {
            .signup-visual {
                display: block;
            }
        }

        .signup-form-side {
            flex: 1.2;
            padding: 3rem 4rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .signup-header h2 {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            background: linear-gradient(to right, #fff, var(--primary-orange));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .signup-header p {
            opacity: 0.6;
            margin-bottom: 2rem;
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }

        @media (max-width: 640px) {
            .form-grid {
                grid-template-columns: 1fr;
            }
        }

        .form-group {
            margin-bottom: 1.2rem;
        }

        .form-group.full-width {
            grid-column: span 2;
        }

        @media (max-width: 640px) {
            .form-group.full-width {
                grid-column: span 1;
            }
        }

        .form-group label {
            display: block;
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            opacity: 0.8;
        }

        .input-wrapper input {
            width: 100%;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 0.9rem 1.2rem;
            border-radius: 12px;
            color: white;
            font-size: 0.95rem;
            outline: none;
            transition: var(--transition);
        }

        .input-wrapper input:focus {
            border-color: var(--primary-orange);
            background: rgba(255, 255, 255, 0.1);
            box-shadow: 0 0 0 4px rgba(255, 90, 31, 0.1);
        }

        .terms-check {
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
            margin: 1rem 0;
            font-size: 0.85rem;
            opacity: 0.7;
        }

        .terms-check input {
            margin-top: 0.25rem;
            accent-color: var(--primary-orange);
        }

        .signup-btn {
            width: 100%;
            background: var(--primary-orange);
            color: white;
            border: none;
            padding: 1.1rem;
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: var(--transition);
            margin-top: 1rem;
        }

        .signup-btn:hover {
            background: var(--primary-orange-hover);
            transform: translateY(-2px);
            box-shadow: 0 12px 24px rgba(255, 90, 31, 0.3);
        }

        .signup-btn:disabled {
            background: #4B5563;
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        .social-divider {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin: 1.5rem 0;
            opacity: 0.3;
            font-size: 0.8rem;
        }

        .social-divider::before,
        .social-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: white;
        }

        .login-link {
            text-align: center;
            margin-top: 2rem;
            opacity: 0.7;
            font-size: 0.95rem;
        }

        .login-link a {
            color: var(--primary-orange);
            text-decoration: none;
            font-weight: 700;
        }

        .login-link a:hover {
            text-decoration: underline;
        }

        /* --- Error Alert Styling --- */
        .error-alert {
            background: rgba(239, 68, 68, 0.1);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(239, 68, 68, 0.2);
            padding: 1rem 1.25rem;
            border-radius: 16px;
            color: #ef4444;
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 2rem;
            animation: slideDown 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .error-alert i {
            font-size: 1.1rem;
        }

        .error-alert span {
            font-size: 0.9rem;
            font-weight: 600;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body>
    <header>
        <a href="/" class="logo">
            <img src="/public/public/logo-icon.png" alt="ZiGo Icon" class="icon">
            <img src="/public/public/logo-name.png" alt="ZiGo" class="name">
        </a>
        <ul class="nav-links hidden lg:flex"
            style="display: flex; gap: 2rem; list-style: none; margin-left: auto; margin-right: 2rem;">
            <li><a href="/" style="color: white; text-decoration: none; font-weight: 500; opacity: 0.8;">Home</a></li>
            <li><a href="/shop" style="color: white; text-decoration: none; font-weight: 500; opacity: 0.8;">Shop</a>
            </li>
            <li><a href="/categories"
                    style="color: white; text-decoration: none; font-weight: 500; opacity: 0.8;">Categories</a>
            </li>
            <li><a href="/orders"
                    style="color: white; text-decoration: none; font-weight: 500; opacity: 0.8;">Orders</a></li>
            <li><a href="/about" style="color: white; text-decoration: none; font-weight: 500; opacity: 0.8;">About</a>
            </li>
            <li><a href="/contact"
                    style="color: white; text-decoration: none; font-weight: 500; opacity: 0.8;">Contact</a></li>
        </ul>
    </header>

    <div class="signup-container">
        <div class="signup-card" id="signupCard">
            <div class="signup-visual">
                <div class="absolute bottom-12 left-12 z-10 p-8">
                    <h3 class="text-3xl font-extrabold text-white mb-2">Join ZiGo.</h3>
                    <p class="text-white/60">The next generation of tech shopping starts with you.</p>
                </div>
            </div>

            <div class="signup-form-side">
                <div class="signup-header text-center lg:text-left">
                    <h2>Create Account</h2>
                    <p style="margin-bottom: 3px;">Be part of the tech revolution.</p>

                    <% if (locals.error && error.length> 0) { %>
                        <div class="error-alert">
                            <i class="fas fa-exclamation-circle"></i>
                            <span>
                                <%= error %>
                            </span>
                        </div>
                        <% } %>
                </div>

                <form action="/signUp" method="POST">
                    <div class="form-grid">
                        <div class="form-group full-width">
                            <label for="userName">User Name</label>
                            <div class="input-wrapper">
                                <input type="text" id="userName" name="userName" placeholder="e.g. john">
                            </div>
                            <p id="UserNameError"
                                style="color: red; font-size: 0.8rem; margin-top: 5px; display: none;"></p>
                        </div>
                        <div class="form-group full-width">
                            <label for="email">Email Address</label>
                            <div class="input-wrapper">
                                <input type="email" id="email" name="email" placeholder="john@example.com">
                            </div>
                            <p id="EmailError" style="color: red; font-size: 0.8rem; margin-top: 5px; display: none;">
                            </p>
                        </div>
                        <div class="form-group">
                            <label for="password">Password</label>
                            <div class="input-wrapper" style="position: relative;">
                                <input type="password" id="password" name="password" placeholder="••••••••"
                                    style="padding-right: 40px;">
                                <button type="button" onclick="togglePasswordVisibility('password', this)"
                                    style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: white; opacity: 0.7;">
                                    <svg class="eye-open" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                        stroke-linejoin="round">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                        <circle cx="12" cy="12" r="3"></circle>
                                    </svg>
                                    <svg class="eye-closed" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                        stroke-linejoin="round" style="display: none;">
                                        <path
                                            d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24">
                                        </path>
                                        <line x1="1" y1="1" x2="23" y2="23"></line>
                                    </svg>
                                </button>
                            </div>
                            <p id="PasswordError"
                                style="color: red; font-size: 0.8rem; margin-top: 5px; display: none;">
                            </p>
                        </div>
                        <div class="form-group">
                            <label for="confirmPassword">Confirm Password</label>
                            <div class="input-wrapper" style="position: relative;">
                                <input type="password" id="confirmPassword" name="confirmPassword"
                                    placeholder="••••••••" style="padding-right: 40px;">
                                <button type="button" onclick="togglePasswordVisibility('confirmPassword', this)"
                                    style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: white; opacity: 0.7;">
                                    <svg class="eye-open" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                        stroke-linejoin="round">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                        <circle cx="12" cy="12" r="3"></circle>
                                    </svg>
                                    <svg class="eye-closed" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                        stroke-linejoin="round" style="display: none;">
                                        <path
                                            d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24">
                                        </path>
                                        <line x1="1" y1="1" x2="23" y2="23"></line>
                                    </svg>
                                </button>
                            </div>
                            <p id="ConfirmPasswordError"
                                style="color: red; font-size: 0.8rem; margin-top: 5px; display: none;"></p>
                        </div>
                        <div class="form-group full-width">
                            <label for="referralCode">Referral Code (Optional)</label>
                            <div class="input-wrapper">
                                <input type="text" id="referralCode" name="referralCode" placeholder="ZIGO-XXXXXX">
                            </div>
                            <div class="flex items-center gap-2 mt-2">
                                <div class="w-1.5 h-1.5 rounded-full bg-[#FF5A1F]"></div>
                                <p class="text-[0.7rem] font-bold text-[#FF5A1F] uppercase tracking-wider">Friend Bonus:
                                    Get ₹100</p>
                            </div>
                        </div>
                    </div>

                    <div class="terms-check">
                        <input type="checkbox" id="terms" name="terms">
                        <label for="terms">I agree to the <a href="/public/htmls/terms.html" target="_blank"
                                rel="noopener noreferrer" class="text-[#FF5A1F]">Terms of Service</a>
                            and <a href="/public/htmls/privacy.html" target="_blank" rel="noopener noreferrer"
                                class="text-[#FF5A1F]">Privacy Policy</a>.</label>
                    </div>

                    <button type="submit" id="signupSubmit" class="signup-btn" disabled>Create Your ZiGo
                        Account</button>
                </form>

                <div class="social-divider">Or join with</div>
                <div class="social-btns flex flex-col sm:flex-row gap-4">
                    <a href="/auth/google"
                        class="social-btn w-full bg-white/5 border border-white/10 rounded-xl p-3 text-white flex justify-center items-center gap-2 hover:bg-white/10 transition-colors">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path
                                d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                                fill="#4285F4" />
                            <path
                                d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                                fill="#34A853" />
                            <path
                                d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                                fill="#FBBC05" />
                            <path
                                d="M12 5.38c1.62 0 3.06.56 4.21 1.66l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                                fill="#EA4335" />
                        </svg>
                        Google
                    </a>
                </div>

                <p class="login-link">
                    Already a member? <a href="/login">Sign In</a>
                </p>
            </div>
        </div>
    </div>

    <script>
        function togglePasswordVisibility(inputId, btn) {
            const passwordInput = document.getElementById(inputId);
            const eyeOpen = btn.querySelector(".eye-open");
            const eyeClosed = btn.querySelector(".eye-closed");

            if (passwordInput.type === "password") {
                passwordInput.type = "text";
                eyeOpen.style.display = "none";
                eyeClosed.style.display = "block";
            } else {
                passwordInput.type = "password";
                eyeOpen.style.display = "block";
                eyeClosed.style.display = "none";
            }
        }

        window.onload = () => {
            document.getElementById('signupCard').classList.add('active');

            const signupForm = document.querySelector('form');
            const signupBtn = document.getElementById('signupSubmit');
            const termsBox = document.getElementById('terms');

            // Inputs
            const nameInput = document.getElementById('userName');
            const emailInput = document.getElementById('email');
            const passInput = document.getElementById('password');
            const confirmInput = document.getElementById('confirmPassword');

            // Error Elements
            const nameError = document.getElementById('UserNameError');
            const emailError = document.getElementById('EmailError');
            const passError = document.getElementById('PasswordError');
            const confirmError = document.getElementById('ConfirmPasswordError');

            const validateField = (input, errorEl, message, validator) => {
                const isValid = validator(input.value.trim());
                if (!isValid) {
                    errorEl.textContent = message;
                    errorEl.style.display = 'block';
                    input.style.borderColor = 'rgba(255, 0, 0, 0.5)';
                    return false;
                } else {
                    errorEl.style.display = 'none';
                    input.style.borderColor = 'rgba(255, 255, 255, 0.1)';
                    return true;
                }
            };

            const validators = {
                name: (val) => val.length >= 3,
                nameCheckNumber: (val) => !/\d/.test(val),
                email: (val) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val),
                pass: (val) => val.length >= 6
            };

            termsBox.addEventListener('change', () => {
                signupBtn.disabled = !termsBox.checked;
                signupBtn.style.opacity = termsBox.checked ? '1' : '0.5';
            });

            signupForm.addEventListener('submit', (e) => {
                let isFormValid = true;

                if (!validateField(nameInput, nameError, "Name must be at least 3 characters", validators.name)) isFormValid = false;
                if (!validateField(nameInput, nameError, "Name can't contain numbers", validators.nameCheckNumber)) isFormValid = false;
                if (!validateField(emailInput, emailError, "Please enter a valid email address", validators.email)) isFormValid = false;
                if (!validateField(passInput, passError, "Password must be at least 6 characters", validators.pass)) isFormValid = false;

                if (passInput.value !== confirmInput.value) {
                    confirmError.textContent = "Passwords do not match";
                    confirmError.style.display = 'block';
                    confirmInput.style.borderColor = 'rgba(255, 0, 0, 0.5)';
                    isFormValid = false;
                } else {
                    confirmError.style.display = 'none';
                    confirmInput.style.borderColor = 'rgba(255, 255, 255, 0.1)';
                }

                if (!isFormValid) {
                    e.preventDefault();
                    // Scroll to first error
                    const firstError = document.querySelector('[id$="Error"][style*="block"]');
                    if (firstError) firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
            });
        }
    </script>
</body>

</html>